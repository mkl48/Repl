			_activeGoal = nil,\
			_activeLatestP = {},\
			_activeLatestV = {},\
			_activeNumSprings = 0,\
			_activeSpeed = -1,\
			_activeStartP = {},\
			_activeStartV = {},\
			_activeTargetP = {},\
			_activeType = \"\",\
			_damping = damping,\
