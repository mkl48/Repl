-- Equivalent to f_inv. Takes a linear sRGB channel and returns\
-- the sRGB channel\
local function transform(channel: number): number\
    if channel >= 0.04045 then\
        return ((channel + 0.055)/(1 + 0.055))^2.4\
    else\
        return channel / 12.92\
    end\
end\
