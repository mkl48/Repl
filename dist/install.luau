-- Equivalent to f. Takes an sRGB channel and returns\
-- the linear sRGB channel\
local function inverse(channel: number): number\
    if channel >= 0.0031308 then\
        return (1.055) * channel^(1.0/2.4) - 0.055\
    else\
        return 12.92 * channel\
    end\
end\
