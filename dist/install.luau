{"Repl/_Main/Client","ModuleScript","--- The **client realm**: the visible command [[Bar]] plus the headless pieces\
--- that drive it — the [[Completer]] (autocomplete) and [[History]]. The\
--- realm-aware `Repl.Start` wires a Bar to the dispatcher and network once those\
--- land; until then, mount a Bar directly with `Client.Bar.new{...}`.\
---\
--- Requiring this pulls Fusion (via Bar), so it's client/Studio-only — the\
--- server realm never touches it.\
--- @section Client\
--- @client\
\
local Client = {}\
\
Client.Bar = require(script.Bar)\
Client.Completer = require(script.Completer)\
Client.History = require(script.History)\
\
return Client\
"},
{"Repl/_Main/Client/Bar","ModuleScript","--- The **command bar** — the visible surface. A bottom-anchored terminal: a\
--- scrolling output area, a prompt + TextBox input with a custom **block cursor**\
--- and inline **ghost text**, and an **autocomplete popover** with a highlighted,\
--- arrow-cyclable selection. While the bar is focused it takes over input —\
--- character movement, shift-lock, and the backpack hotkey are suppressed so a\
--- keystroke never leaks to the game. Enter submits to the injected `submit`\
--- callback; Ctrl dismisses the suggestions; Backquote toggles; Escape hides.\
--- Output is drawn by the [[Terminal]] renderer and recolors live with the\
--- [[Theme]]. Exposes dev-facing state (`Focused`, `Visible`) and events\
--- (`Opened`, `Closed`, `FocusChanged`, `Submitted`). Studio-only (pulls Fusion).\
--- @section Client\
--- @client\
\
local Players = game:GetService(\"Players\")\
local UserInputService = game:GetService(\"UserInputService\")\
local ContextActionService = game:GetService(\"ContextActionService\")\
local StarterGui = game:GetService(\"StarterGui\")\
local TextService = game:GetService(\"TextService\")\
\
local Fusion = require(script.Parent.Parent.Parent._Packages.Fusion)\
local Theming = require(script.Parent.Parent.Parent._Utility.Render.Theming)\
local Terminal = require(script.Parent.Parent.Parent._Utility.Render.Terminal)\
local Output = require(script.Parent.Parent.Parent._Utility.Render.Output)\
local Signal = require(script.Parent.Parent.Parent._Utility.Signal)\
local Completer = require(script.Parent.Completer)\
local History = require(script.Parent.History)\
\
local peek = Fusion.peek\
local scoped = Fusion.scoped\
local Children = Fusion.Children\
local OnEvent = Fusion.OnEvent\
local OnChange = Fusion.OnChange\
\
local Bar = {}\
Bar.__index = Bar\
\
export type Config = {\
	registry: any, -- a Registry (for completions)\
	submit: ((text: string) -> ())?, -- runs a submitted line\
	prompt: string?, -- the prompt path, e.g. \"Arena/kr3ative/repl\"\
	parent: Instance?, -- defaults to a fresh ScreenGui in PlayerGui\
	activationKeys: { Enum.KeyCode }?, -- default { Backquote }\
	cursorStyle: (\"block\" | \"line\" | \"underline\")?, -- default \"block\"\
	compact: boolean?, -- single-bar (Cmdr-like) layout instead of the full panel\
	width: number?, -- compact bar width in px (default 720)\
	align: (\"Top\" | \"Bottom\" | \"Center\")?, -- where the bar sits (default Bottom)\
	intellisense: boolean?, -- show the signature hint line (default true)\
}\
\
local FONT = Enum.Font.Code\
local TEXT_SIZE = 16\
local ROW_HEIGHT = 30\
local COMPLETION_HEIGHT = 24\
local BLINK_PERIOD = 0.53\
\
-- width of one monospace character in the terminal font (computed once)\
local function charWidth(): number\
	local size = TextService:GetTextSize(\"M\", TEXT_SIZE, FONT, Vector2.new(1e6, 1e6))\
	return size.X\
end\
\
--- Creates and mounts the bar. Returns a bar handle.\
function Bar.new(config: Config)\
	local self = setmetatable({}, Bar)\
	local scope = scoped(Fusion)\
\
	self._scope = scope\
	self._registry = config.registry\
	self._submit = config.submit\
	self._history = History.new()\
	self._connections = {} :: { RBXScriptConnection }\
	self._prompt = config.prompt or \"kr3ative/repl\"\
	self._activationKeys = config.activationKeys or { Enum.KeyCode.Backquote }\
	self._cursorStyle = config.cursorStyle or \"block\"\
	self._compact = config.compact == true\
	self._width = config.width or 720\
	self._align = config.align or \"Bottom\"\
	self._intellisense = config.intellisense ~= false -- default true\
	self._suppressed = false\
\
	-- ── dev-facing state + events ────────────────────────────────────────────\
	self.Opened = Signal.new()\
	self.Closed = Signal.new()\
	self.FocusChanged = Signal.new() -- fires (isFocused: boolean)\
	self.Submitted = Signal.new() -- fires (line: string)\
\
	local input = scope:Value(\"\")\
	local visible = scope:Value(false)\
	local focused = scope:Value(false)\
	local selected = scope:Value(1) -- 1-based index into the completion list\
	local dismissed = scope:Value(false) -- Ctrl hides the popover until the next edit\
	local cursorPos = scope:Value(1)\
	local cursorOn = scope:Value(true) -- blink state\
	self._input, self._visible, self._focused = input, visible, focused\
	self._selected, self._dismissed = selected, dismissed\
\
	-- reactive completions + ghost\
	local completions = scope:Computed(function(use)\
		return Completer.complete(self._registry, use(input))\
	end)\
	local ghost = scope:Computed(function(use)\
		return Completer.ghost(self._registry, use(input))\
	end)\
	local hint = scope:Computed(function(use)\
		if not self._intellisense then\
			return nil\
		end\
		return Completer.hint(self._registry, use(input))\
	end)\
	local popoverOpen = scope:Computed(function(use)\
		if not use(focused) or use(dismissed) then\
			return false\
		end\
		local text = use(input)\
		if string.gsub(text, \"%s\", \"\") == \"\" then\
			return false -- nothing typed\
		end\
		local list = use(completions)\
		if #list == 0 then\
			return false\
		end\
		if #list == 1 then\
			-- the only suggestion is exactly what's already typed → nothing to add\
			local only = list[1]\
			local word = string.sub(text, only.replaceStart, only.replaceEnd)\
			if string.lower(only.text) == string.lower(word) then\
				return false\
			end\
		end\
		return true\
	end)\
	self._completions = completions\
	self._popoverOpen = popoverOpen\
\
	local textBox: TextBox\
\
	local function setInput(text: string)\
		input:set(text)\
		dismissed:set(false)\
		selected:set(1)\
		if textBox then\
			textBox.Text = text\
			textBox.CursorPosition = #text + 1\
		end\
	end\
	self._setInput = setInput\
\
	local function acceptCompletion(completion)\
		local text = peek(input)\
		local before = string.sub(text, 1, completion.replaceStart - 1)\
		setInput(before .. completion.text .. \" \")\
	end\
\
	local function acceptSelected()\
		if peek(popoverOpen) then\
			local list = peek(completions)\
			acceptCompletion(list[peek(selected)] or list[1])\
			return\
		end\
		local suffix = peek(ghost)\
		if suffix ~= \"\" then\
			setInput(peek(input) .. suffix .. \" \")\
		end\
	end\
\
	local function moveSelection(delta: number)\
		local list = peek(completions)\
		if #list == 0 then\
			return\
		end\
		local next = peek(selected) + delta\
		if next < 1 then\
			next = #list\
		elseif next > #list then\
			next = 1\
		end\
		selected:set(next)\
	end\
\
	local function submit()\
		local text = peek(input)\
		if text == \"\" then\
			return\
		end\
		self._history:add(text)\
		self:print(Output.line(\"plain\", {\
			Output.segment(`{self._prompt} `, { color = \"prompt\" }),\
			Output.segment(\"> \", { color = \"muted\" }),\
			Output.segment(text, { color = \"text\" }),\
		}))\
		self.Submitted:Fire(text)\
		if self._submit then\
			self._submit(text)\
		end\
		setInput(\"\")\
	end\
	self._submitLine = submit\
\
	-- ── output area ──────────────────────────────────────────────────────────\
	local outputFrame\
	if self._compact then\
		-- a compact log that grows upward above the bar, capped and clipped\
		outputFrame = scope:New \"Frame\" {\
			Name = \"Output\",\
			BackgroundColor3 = Theming.color(scope, \"bg\"),\
			BackgroundTransparency = 0.15,\
			BorderSizePixel = 0,\
			AutomaticSize = Enum.AutomaticSize.Y,\
			Size = UDim2.new(1, 0, 0, 0),\
			ClipsDescendants = true,\
			Visible = false, -- shown once something is printed\
			LayoutOrder = 1,\
			[Children] = {\
				scope:New \"UICorner\" { CornerRadius = UDim.new(0, 6) },\
				scope:New \"UISizeConstraint\" { MaxSize = Vector2.new(math.huge, 240) },\
				scope:New \"UIPadding\" {\
					PaddingTop = UDim.new(0, 6),\
					PaddingBottom = UDim.new(0, 6),\
					PaddingLeft = UDim.new(0, 10),\
					PaddingRight = UDim.new(0, 10),\
				},\
				scope:New \"UIListLayout\" {\
					FillDirection = Enum.FillDirection.Vertical,\
					SortOrder = Enum.SortOrder.LayoutOrder,\
					VerticalAlignment = Enum.VerticalAlignment.Bottom,\
					Padding = UDim.new(0, 2),\
				},\
			},\
		}\
	else\
		outputFrame = scope:New \"ScrollingFrame\" {\
			Name = \"Output\",\
			BackgroundTransparency = 1,\
			BorderSizePixel = 0,\
			Size = UDim2.new(1, -16, 1, -(ROW_HEIGHT + 12)),\
			Position = UDim2.fromOffset(8, 4),\
			CanvasSize = UDim2.new(),\
			AutomaticCanvasSize = Enum.AutomaticSize.Y,\
			ScrollBarThickness = 4,\
			ScrollBarImageColor3 = Theming.color(scope, \"muted\"),\
			ScrollingDirection = Enum.ScrollingDirection.Y,\
			[Children] = {\
				scope:New \"UIListLayout\" {\
					FillDirection = Enum.FillDirection.Vertical,\
					SortOrder = Enum.SortOrder.LayoutOrder,\
					Padding = UDim.new(0, 2),\
				},\
			},\
		}\
	end\
	self._outputFrame = outputFrame\
\
	-- ── autocomplete popover (semi-transparent; square in full, rounded compact)\
	local popover = scope:New \"Frame\" {\
		Name = \"Autocomplete\",\
		BackgroundColor3 = Theming.color(scope, \"bgAlt\"),\
		BackgroundTransparency = 0.06,\
		BorderSizePixel = 0,\
		AutomaticSize = Enum.AutomaticSize.Y,\
		Size = if self._compact then UDim2.new(1, 0, 0, 0) else UDim2.new(0, 340, 0, 0),\
		Position = if self._compact then UDim2.new(0, 0, 0, 0) else UDim2.new(0, 8, 1, -(ROW_HEIGHT + 6)),\
		AnchorPoint = if self._compact then Vector2.new(0, 0) else Vector2.new(0, 1),\
		LayoutOrder = 2,\
		Visible = popoverOpen,\
		[Children] = {\
			scope:New \"UICorner\" { CornerRadius = UDim.new(0, if self._compact then 6 else 0) },\
			scope:New \"UIStroke\" { Color = Theming.color(scope, \"border\"), Thickness = 1 },\
			scope:New \"UIListLayout\" {\
				FillDirection = Enum.FillDirection.Vertical,\
				SortOrder = Enum.SortOrder.LayoutOrder,\
			},\
			scope:ForPairs(completions, function(_use, rowScope, index, completion)\
				local row = rowScope:New \"TextButton\" {\
					Name = \"Completion\",\
					LayoutOrder = index,\
					BackgroundColor3 = Theming.color(rowScope, \"selection\"),\
					-- highlight the indexed row; others are transparent\
					BackgroundTransparency = rowScope:Computed(function(use)\
						return if use(selected) == index then 0 else 1\
					end),\
					AutoButtonColor = false,\
					Size = UDim2.new(1, 0, 0, COMPLETION_HEIGHT),\
					Font = FONT,\
					TextSize = 15,\
					TextXAlignment = Enum.TextXAlignment.Left,\
					TextColor3 = rowScope:Computed(function(use)\
						return Color3.fromHex(Theming.hex(if use(selected) == index then \"text\" else \"muted\"))\
					end),\
					Text = `  {completion.text}`,\
					[Children] = {\
						rowScope:New \"UIPadding\" {\
							PaddingLeft = UDim.new(0, 6),\
							PaddingRight = UDim.new(0, 6),\
						},\
						rowScope:New \"TextLabel\" {\
							Name = \"Detail\",\
							BackgroundTransparency = 1,\
							Size = UDim2.new(1, -8, 1, 0),\
							Font = FONT,\
							TextSize = 13,\
							TextXAlignment = Enum.TextXAlignment.Right,\
							TextColor3 = Theming.color(rowScope, \"muted\"),\
							Text = completion.detail,\
						},\
					},\
					[OnEvent \"MouseEnter\"] = function()\
						selected:set(index)\
					end,\
					[OnEvent \"Activated\"] = function()\
						acceptCompletion(completion)\
						if textBox then\
							textBox:CaptureFocus()\
						end\
					end,\
				}\
				return index, row\
			end),\
		},\
	}\
\
	-- ── input row: prompt + field (ghost, textbox, cursor) ───────────────────\
	local promptLabel = scope:New \"TextLabel\" {\
		Name = \"Prompt\",\
		BackgroundTransparency = 1,\
		AutomaticSize = Enum.AutomaticSize.X,\
		Size = UDim2.new(0, 0, 1, 0),\
		Font = FONT,\
		TextSize = TEXT_SIZE,\
		TextXAlignment = Enum.TextXAlignment.Left,\
		TextColor3 = Theming.color(scope, \"prompt\"),\
		Text = `{self._prompt} > `,\
	}\
\
	local ghostLabel = scope:New \"TextLabel\" {\
		Name = \"Ghost\",\
		BackgroundTransparency = 1,\
		Size = UDim2.new(1, 0, 1, 0),\
		Font = FONT,\
		TextSize = TEXT_SIZE,\
		TextXAlignment = Enum.TextXAlignment.Left,\
		TextColor3 = Theming.color(scope, \"muted\"),\
		ZIndex = 1,\
		Text = scope:Computed(function(use)\
			local suffix = use(ghost)\
			if suffix == \"\" or use(popoverOpen) then\
				return \"\" -- don't ghost while the popover is showing a selection\
			end\
			return use(input) .. suffix\
		end),\
	}\
\
	-- custom terminal cursor (block by default), positioned at the caret\
	local cw = charWidth()\
	local cursor = scope:New \"Frame\" {\
		Name = \"Cursor\",\
		BorderSizePixel = 0,\
		BackgroundColor3 = Theming.color(scope, \"cursor\"),\
		BackgroundTransparency = scope:Computed(function(use)\
			return if use(focused) and use(cursorOn) then 0.35 else 1\
		end),\
		ZIndex = 3,\
		AnchorPoint = Vector2.new(0, 0.5),\
		Position = scope:Computed(function(use)\
			return UDim2.new(0, (use(cursorPos) - 1) * cw, 0.5, 0)\
		end),\
		Size = (function()\
			if self._cursorStyle == \"line\" then\
				return UDim2.new(0, 2, 0, TEXT_SIZE + 2)\
			elseif self._cursorStyle == \"underline\" then\
				return UDim2.new(0, cw, 0, 2)\
			end\
			return UDim2.new(0, cw, 0, TEXT_SIZE + 2) -- block\
		end)(),\
	}\
	if self._cursorStyle == \"underline\" then\
		cursor.AnchorPoint = Vector2.new(0, 1)\
		cursor.Position = scope:Computed(function(use)\
			return UDim2.new(0, (use(cursorPos) - 1) * cw, 1, -2)\
		end)\
	end\
\
	-- signature intellisense, right-aligned in the field (e.g. `theme <name>`)\
	local hintLabel = scope:New \"TextLabel\" {\
		Name = \"Hint\",\
		BackgroundTransparency = 1,\
		AnchorPoint = Vector2.new(1, 0.5),\
		Position = UDim2.new(1, -4, 0.5, 0),\
		AutomaticSize = Enum.AutomaticSize.X,\
		Size = UDim2.new(0, 0, 1, 0),\
		Font = FONT,\
		TextSize = 13,\
		TextXAlignment = Enum.TextXAlignment.Right,\
		TextYAlignment = Enum.TextYAlignment.Center,\
		RichText = true,\
		ZIndex = 1,\
		Visible = scope:Computed(function(use)\
			return use(hint) ~= nil\
		end),\
		Text = scope:Computed(function(use)\
			use(Theming.scheme)\
			local h = use(hint)\
			if not h then\
				return \"\"\
			end\
			local muted, accent = Theming.hex(\"muted\"), Theming.hex(\"accent\")\
			local parts = { `<font color=\"{muted}\">{h.name}</font>` }\
			for i, arg in h.args do\
				local usage = if arg.optional then `[{arg.name}]` else `<{arg.name}>`\
				local color = if i == h.activeIndex then accent else muted\
				table.insert(parts, `<font color=\"{color}\">{usage}</font>`)\
			end\
			return table.concat(parts, \" \")\
		end),\
	}\
\
	textBox = scope:New \"TextBox\" {\
		Name = \"Input\",\
		BackgroundTransparency = 1,\
		Size = UDim2.new(1, 0, 1, 0),\
		Font = FONT,\
		TextSize = TEXT_SIZE,\
		TextXAlignment = Enum.TextXAlignment.Left,\
		TextColor3 = Theming.color(scope, \"text\"),\
		ClearTextOnFocus = false,\
		Text = \"\",\
		PlaceholderText = \"type a command…\",\
		PlaceholderColor3 = Theming.color(scope, \"muted\"),\
		ZIndex = 2,\
		[OnChange \"Text\"] = function(newText)\
			-- the Tab/Enter we handle for completion also reaches the box as a\
			-- literal character; strip it so it never lands in the input\
			if string.find(newText, \"[\\t\\n]\") then\
				textBox.Text = (string.gsub(newText, \"[\\t\\n]\", \"\"))\
				return -- the rewrite re-fires this handler cleanly\
			end\
			input:set(newText)\
			dismissed:set(false)\
			selected:set(1)\
			cursorPos:set((textBox and textBox.CursorPosition) or (#newText + 1))\
		end,\
		[OnChange \"CursorPosition\"] = function(pos)\
			if pos and pos > 0 then\
				cursorPos:set(pos)\
			end\
		end,\
		[OnEvent \"Focused\"] = function()\
			focused:set(true)\
			self:_suppressGameInput(true)\
			self.FocusChanged:Fire(true)\
		end,\
		[OnEvent \"FocusLost\"] = function(enterPressed)\
			if enterPressed then\
				submit()\
				task.defer(function()\
					if peek(visible) then\
						textBox:CaptureFocus()\
					end\
				end)\
			else\
				focused:set(false)\
				self:_suppressGameInput(false)\
				self.FocusChanged:Fire(false)\
			end\
		end,\
	}\
	self._textBox = textBox\
\
	-- shared input row (prompt + field); placed differently per mode\
	local inputRow = scope:New \"Frame\" {\
		Name = \"InputRow\",\
		BackgroundTransparency = 1,\
		Size = UDim2.new(1, 0, 1, 0),\
		[Children] = {\
			scope:New \"UIListLayout\" {\
				FillDirection = Enum.FillDirection.Horizontal,\
				SortOrder = Enum.SortOrder.LayoutOrder,\
				VerticalAlignment = Enum.VerticalAlignment.Center,\
			},\
			scope:New \"UIPadding\" { PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10) },\
			promptLabel,\
			scope:New \"Frame\" {\
				Name = \"Field\",\
				BackgroundTransparency = 1,\
				Size = UDim2.new(0, 0, 1, 0),\
				[Children] = {\
					scope:New \"UIFlexItem\" { FlexMode = Enum.UIFlexMode.Fill },\
					ghostLabel,\
					hintLabel,\
					cursor,\
					textBox,\
				},\
			},\
		},\
	}\
\
	local container\
	local align = self._align\
	if self._compact then\
		-- one Cmdr-like bar; the log + popover stack away from the aligned edge\
		local bar = scope:New \"Frame\" {\
			Name = \"Bar\",\
			BackgroundColor3 = Theming.color(scope, \"bg\"),\
			BackgroundTransparency = 0.05,\
			BorderSizePixel = 0,\
			Size = UDim2.new(1, 0, 0, ROW_HEIGHT + 14),\
			[Children] = {\
				scope:New \"UICorner\" { CornerRadius = UDim.new(0, 6) },\
				scope:New \"UIStroke\" { Color = Theming.color(scope, \"border\"), Thickness = 1 },\
				inputRow,\
			},\
		}\
		-- when not bottom-aligned the input leads and the popover drops below it\
		local popoverBelow = align ~= \"Bottom\"\
		bar.LayoutOrder = if popoverBelow then 1 else 3\
		popover.LayoutOrder = 2\
		outputFrame.LayoutOrder = if popoverBelow then 3 else 1\
		local anchor, vis, hid\
		if align == \"Top\" then\
			anchor, vis, hid = Vector2.new(0.5, 0), UDim2.new(0.5, 0, 0, 12), UDim2.new(0.5, 0, -0.6, 0)\
		elseif align == \"Center\" then\
			anchor, vis, hid = Vector2.new(0.5, 0.5), UDim2.new(0.5, 0, 0.5, 0), UDim2.new(0.5, 0, -0.6, 0)\
		else\
			anchor, vis, hid = Vector2.new(0.5, 1), UDim2.new(0.5, 0, 1, -12), UDim2.new(0.5, 0, 1.6, 0)\
		end\
		container = scope:New \"Frame\" {\
			Name = \"ReplBar\",\
			BackgroundTransparency = 1,\
			AnchorPoint = anchor,\
			Size = UDim2.new(0, self._width, 0, 0),\
			AutomaticSize = Enum.AutomaticSize.Y,\
			Position = scope:Spring(\
				scope:Computed(function(use)\
					return if use(visible) then vis else hid\
				end),\
				28,\
				1\
			),\
			[Children] = {\
				scope:New \"UIListLayout\" {\
					FillDirection = Enum.FillDirection.Vertical,\
					SortOrder = Enum.SortOrder.LayoutOrder,\
					HorizontalAlignment = Enum.HorizontalAlignment.Center,\
					VerticalAlignment = if popoverBelow then Enum.VerticalAlignment.Top else Enum.VerticalAlignment.Bottom,\
					Padding = UDim.new(0, 6),\
				},\
				outputFrame,\
				popover,\
				bar,\
			},\
		}\
	else\
		inputRow.AnchorPoint = Vector2.new(0, 1)\
		inputRow.Position = UDim2.new(0, 0, 1, -6)\
		inputRow.Size = UDim2.new(1, 0, 0, ROW_HEIGHT)\
		-- the full panel just docks to the chosen edge (internals unchanged)\
		local anchor, vis, hid\
		if align == \"Top\" then\
			anchor, vis, hid = Vector2.new(0, 0), UDim2.new(0, 0, 0, 0), UDim2.new(0, 0, -0.45, 0)\
		elseif align == \"Center\" then\
			anchor, vis, hid = Vector2.new(0, 0.5), UDim2.new(0, 0, 0.5, 0), UDim2.new(0, 0, -0.45, 0)\
		else\
			anchor, vis, hid = Vector2.new(0, 1), UDim2.new(0, 0, 1, 0), UDim2.new(0, 0, 1.45, 0)\
		end\
		container = scope:New \"Frame\" {\
			Name = \"ReplBar\",\
			BackgroundColor3 = Theming.color(scope, \"bg\"),\
			BorderSizePixel = 0,\
			Size = UDim2.new(1, 0, 0.4, 0),\
			AnchorPoint = anchor,\
			Position = scope:Spring(\
				scope:Computed(function(use)\
					return if use(visible) then vis else hid\
				end),\
				28,\
				1\
			),\
			[Children] = {\
				scope:New \"UIStroke\" { Color = Theming.color(scope, \"border\"), Thickness = 1 },\
				outputFrame,\
				popover,\
				inputRow,\
			},\
		}\
	end\
\
	self._gui = scope:New \"ScreenGui\" {\
		Name = \"Repl\",\
		ResetOnSpawn = false,\
		IgnoreGuiInset = true,\
		DisplayOrder = 1000,\
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,\
		Parent = config.parent or (Players.LocalPlayer and Players.LocalPlayer:WaitForChild(\"PlayerGui\")),\
		[Children] = { container },\
	}\
\
	-- blink the cursor\
	self._blink = task.spawn(function()\
		while true do\
			task.wait(BLINK_PERIOD)\
			cursorOn:set(not peek(cursorOn))\
		end\
	end)\
\
	-- ── activation key (sunk via CAS so ` doesn't also open the backpack) ─────\
	self:setActivationKeys(self._activationKeys)\
\
	-- ── in-terminal keys (only act while open + focused) ─────────────────────\
	table.insert(\
		self._connections,\
		UserInputService.InputBegan:Connect(function(inputObject)\
			if not peek(visible) then\
				return\
			end\
			local key = inputObject.KeyCode\
			-- Escape closes even after it has just dropped the TextBox's focus\
			if key == Enum.KeyCode.Escape then\
				self:hide()\
				return\
			end\
			if not textBox:IsFocused() then\
				return\
			end\
			if key == Enum.KeyCode.Up then\
				if peek(popoverOpen) then\
					moveSelection(-1)\
				else\
					local entry = self._history:up(peek(input))\
					if entry then\
						setInput(entry)\
					end\
				end\
			elseif key == Enum.KeyCode.Down then\
				if peek(popoverOpen) then\
					moveSelection(1)\
				else\
					local entry = self._history:down()\
					if entry then\
						setInput(entry)\
					end\
				end\
			elseif key == Enum.KeyCode.Tab then\
				acceptSelected()\
			elseif key == Enum.KeyCode.LeftControl or key == Enum.KeyCode.RightControl then\
				dismissed:set(true)\
			end\
		end)\
	)\
\
	return self\
end\
\
-- suppress/restore character movement, shift-lock, and the backpack hotkey while\
-- the terminal has focus, so keystrokes never leak to the game\
function Bar:_suppressGameInput(on: boolean)\
	if on == self._suppressed then\
		return\
	end\
	self._suppressed = on\
	local player = Players.LocalPlayer\
	if not player then\
		return\
	end\
\
	if on then\
		-- character controls (this also neutralizes shift-lock/movement while\
		-- typing; DevEnableMouseLock can't be set from a script, so we don't try)\
		pcall(function()\
			local playerModule = require(player:WaitForChild(\"PlayerScripts\"):WaitForChild(\"PlayerModule\")) :: any\
			self._controls = playerModule:GetControls()\
			self._controls:Disable()\
		end)\
		-- backpack hotkey / gui\
		pcall(function()\
			StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)\
		end)\
	else\
		if self._controls then\
			pcall(function()\
				self._controls:Enable()\
			end)\
		end\
		pcall(function()\
			StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, true)\
		end)\
	end\
end\
\
--- (Re)binds the activation key(s), sinking them so they don't leak to core UI.\
function Bar:setActivationKeys(keys: { Enum.KeyCode })\
	self._activationKeys = keys\
	pcall(function()\
		ContextActionService:UnbindAction(\"ReplToggle\")\
	end)\
	ContextActionService:BindAction(\"ReplToggle\", function(_, state)\
		if state == Enum.UserInputState.Begin then\
			self:toggle()\
		end\
		return Enum.ContextActionResult.Sink\
	end, false, table.unpack(keys))\
end\
\
--- Appends a rendered [[Output]] node to the terminal.\
function Bar:print(node: Output.Node)\
	local instance = Terminal.render(self._scope, node)\
	instance.Parent = self._outputFrame\
	if self._compact then\
		self._outputFrame.Visible = true -- reveal the compact log on first output\
	end\
	return instance\
end\
\
--- Convenience: append a plain text line of the given kind.\
function Bar:printText(kind: string, text: string)\
	return self:print(Output.line(kind, text))\
end\
\
--- Whether the bar is currently open.\
function Bar:IsOpen(): boolean\
	return Fusion.peek(self._visible)\
end\
\
--- Whether the input is currently focused.\
function Bar:IsFocused(): boolean\
	return Fusion.peek(self._focused)\
end\
\
--- Shows the bar and focuses the input.\
function Bar:show()\
	if self:IsOpen() then\
		return\
	end\
	self._visible:set(true)\
	self.Opened:Fire()\
	task.defer(function()\
		self._textBox:CaptureFocus()\
	end)\
end\
\
--- Hides the bar and releases focus.\
function Bar:hide()\
	if not self:IsOpen() then\
		return\
	end\
	self._visible:set(false)\
	self._textBox:ReleaseFocus()\
	self:_suppressGameInput(false)\
	self.Closed:Fire()\
end\
\
--- Flips visibility.\
function Bar:toggle()\
	if self:IsOpen() then\
		self:hide()\
	else\
		self:show()\
	end\
end\
\
--- Tears down the bar and all its state, connections, and input overrides.\
function Bar:destroy()\
	self:_suppressGameInput(false)\
	if self._blink then\
		task.cancel(self._blink)\
	end\
	pcall(function()\
		ContextActionService:UnbindAction(\"ReplToggle\")\
	end)\
	for _, connection in self._connections do\
		connection:Disconnect()\
	end\
	self.Opened:DisconnectAll()\
	self.Closed:DisconnectAll()\
	self.FocusChanged:DisconnectAll()\
	self.Submitted:DisconnectAll()\
	Fusion.doCleanup(self._scope)\
end\
\
return Bar\
"},
{"Repl/_Main/Client/Completer","ModuleScript","--- The **completion engine** behind the bar. Given the current input, it decides\
--- whether the cursor is on the *command name* (fuzzy-matched against the\
--- [[Registry]]) or on an *argument* (whose compiled [[Types|type]] supplies the\
--- suggestions — including a range's enumerated values), and returns ranked\
--- completions with the text span each one replaces. Pure logic: the bar draws\
--- the results, this decides them, so it's fully headless-testable.\
--- @section Client\
--- @client\
\
local Fuzzy = require(script.Parent.Parent.Parent._Utility.Fuzzy)\
local Command = require(script.Parent.Parent.Parent._Classes.Command)\
\
local Completer = {}\
\
--- One suggestion. `replaceStart`/`replaceEnd` are 1-based byte offsets into the\
--- input that the bar overwrites when the completion is accepted.\
export type Completion = {\
	text: string,\
	kind: \"command\" | \"argument\",\
	detail: string, -- a usage/type hint shown beside the entry\
	description: string, -- a longer description, for the intellisense line\
	replaceStart: number,\
	replaceEnd: number,\
}\
\
--- Signature intellisense for the command currently being typed.\
export type Hint = {\
	name: string,\
	signature: string, -- \"name <a> [b]\"\
	description: string,\
	args: { any }, -- the command's arg specs (name/typeExpr/optional/description)\
	activeIndex: number, -- which arg the cursor is on (0 = still on the name)\
}\
\
-- the registry surface the completer needs (kept structural so tests can pass a\
-- real Registry or a stub)\
export type RegistryLike = {\
	all: (self: any) -> { any },\
	resolve: (self: any, nameOrAlias: string) -> any?,\
}\
\
local function splitWords(input: string): ({ string }, boolean)\
	local words = {}\
	for word in string.gmatch(input, \"%S+\") do\
		table.insert(words, word)\
	end\
	local endsWithSpace = input == \"\" or string.match(input, \"%s$\") ~= nil\
	return words, endsWithSpace\
end\
\
--- Produces completions for `input` against `registry` (cursor assumed at end).\
function Completer.complete(registry: RegistryLike, input: string): { Completion }\
	local words, endsWithSpace = splitWords(input)\
\
	local position: number\
	local currentWord: string\
	if endsWithSpace then\
		position = #words + 1 -- starting a fresh token\
		currentWord = \"\"\
	else\
		position = #words\
		currentWord = words[#words] or \"\"\
	end\
\
	local replaceStart = #input - #currentWord + 1\
	local replaceEnd = #input\
	local out: { Completion } = {}\
\
	if position <= 1 then\
		-- completing the command name: fuzzy over names + aliases\
		local names: { string } = {}\
		for _, command in registry:all() do\
			table.insert(names, command.name)\
			for _, alias in command.aliases do\
				table.insert(names, alias)\
			end\
		end\
		for _, match in Fuzzy.filter(currentWord, names) do\
			local command = registry:resolve(match.value)\
			table.insert(out, {\
				text = match.value,\
				kind = \"command\",\
				detail = if command then Command.signature(command) else \"\",\
				description = command and command.description or \"\",\
				replaceStart = replaceStart,\
				replaceEnd = replaceEnd,\
			})\
		end\
	else\
		-- completing an argument or a flag\
		local command = registry:resolve(words[1])\
		if command and string.sub(currentWord, 1, 1) == \"-\" then\
			-- suggest flag names\
			for _, flag in command.flags do\
				for _, alias in flag.names do\
					local dashed = (if #alias == 1 then \"-\" else \"--\") .. alias\
					if string.sub(dashed, 1, #currentWord) == currentWord then\
						table.insert(out, {\
							text = dashed,\
							kind = \"argument\",\
							detail = if flag.description ~= \"\" then flag.description else `--{flag.name}: {flag.typeExpr}`,\
							description = flag.description,\
							replaceStart = replaceStart,\
							replaceEnd = replaceEnd,\
						})\
					end\
				end\
			end\
		elseif command then\
			local arg = command.args[position - 1]\
			if arg then\
				local detail = if arg.description ~= \"\" then arg.description else `{arg.name}: {arg.typeExpr}`\
				for _, suggestion in arg.type.autocomplete(currentWord) do\
					table.insert(out, {\
						text = suggestion,\
						kind = \"argument\",\
						detail = detail,\
						description = arg.description or \"\",\
						replaceStart = replaceStart,\
						replaceEnd = replaceEnd,\
					})\
				end\
			end\
		end\
	end\
\
	return out\
end\
\
--- Signature intellisense for `input`: the resolved command, its usage, and\
--- which argument the cursor is on (0 while still typing the name). Returns nil\
--- when the first word isn't a known command.\
function Completer.hint(registry: RegistryLike, input: string): Hint?\
	local words, endsWithSpace = splitWords(input)\
	if #words == 0 then\
		return nil\
	end\
	local command = registry:resolve(words[1])\
	if not command then\
		return nil\
	end\
	local activeIndex = if endsWithSpace then #words else #words - 1 -- 0 = on the name\
	return {\
		name = command.name,\
		signature = Command.signature(command),\
		description = command.description,\
		args = command.args,\
		activeIndex = activeIndex,\
	}\
end\
\
--- The ghost-text completion of `input`: the remaining characters of the single\
--- best suggestion, if it *extends* the current word (case-insensitive prefix).\
--- Returns \"\" when there's nothing to ghost.\
function Completer.ghost(registry: RegistryLike, input: string): string\
	local completions = Completer.complete(registry, input)\
	local best = completions[1]\
	if not best then\
		return \"\"\
	end\
	local typed = string.sub(input, best.replaceStart, best.replaceEnd)\
	if typed ~= \"\" and string.sub(string.lower(best.text), 1, #typed) == string.lower(typed) then\
		return string.sub(best.text, #typed + 1)\
	end\
	return \"\"\
end\
\
return Completer\
"},
{"Repl/_Main/Client/History","ModuleScript","--- Command **history** for the bar — readline semantics. `add` records a\
--- submitted line (consecutive duplicates and blanks dropped, capped to a limit);\
--- `up`/`down` walk older→newer, and the in-progress line is saved as a *draft*\
--- so pressing Down past the newest entry restores what you were typing. Pure\
--- state, headless-testable.\
--- @section Client\
--- @client\
\
local History = {}\
History.__index = History\
\
--- Creates a history buffer (default cap 100 entries).\
function History.new(limit: number?)\
	return setmetatable({\
		entries = {} :: { string },\
		limit = limit or 100,\
		cursor = nil :: number?, -- nil = at the live line; else an index into entries\
		draft = \"\", -- the live line stashed when navigation began\
	}, History)\
end\
\
--- Records a submitted line and resets navigation. Blank lines and immediate\
--- repeats are ignored.\
function History:add(text: string)\
	local trimmed = (string.gsub(text, \"^%s*(.-)%s*$\", \"%1\"))\
	if trimmed == \"\" then\
		self:reset()\
		return\
	end\
	if self.entries[#self.entries] ~= trimmed then\
		table.insert(self.entries, trimmed)\
		while #self.entries > self.limit do\
			table.remove(self.entries, 1)\
		end\
	end\
	self:reset()\
end\
\
--- Moves to an older entry, stashing `current` as the draft on the first step.\
--- Returns the entry to show, or nil when there's no history.\
function History:up(current: string): string?\
	if #self.entries == 0 then\
		return nil\
	end\
	if self.cursor == nil then\
		self.draft = current\
		self.cursor = #self.entries\
	else\
		self.cursor = math.max(1, self.cursor - 1)\
	end\
	return self.entries[self.cursor]\
end\
\
--- Moves to a newer entry; stepping past the newest restores the draft (and\
--- returns to the live line). Returns nil when not currently navigating.\
function History:down(): string?\
	if self.cursor == nil then\
		return nil\
	end\
	self.cursor += 1\
	if self.cursor > #self.entries then\
		self.cursor = nil\
		return self.draft\
	end\
	return self.entries[self.cursor]\
end\
\
--- Returns to the live line without changing the stored entries.\
function History:reset()\
	self.cursor = nil\
	self.draft = \"\"\
end\
\
--- Every entry, oldest first (a copy).\
function History:all(): { string }\
	return table.clone(self.entries)\
end\
\
return History\
"},
{"Repl/_Main/Server","Folder",nil},
{"Repl/_Main/Server/Dispatcher","ModuleScript","--- The **Dispatcher** runs a submitted line. It tokenizes with the [[Lexer]],\
--- splits on chain operators, and for each command: resolves it in the\
--- [[Registry]], binds the argument tokens (coercing each through the arg's\
--- compiled [[Types|type]], filling defaults, erroring on a missing required\
--- one), runs the handler with a [[Context]], and captures a [[Result]]. Chains\
--- branch on the exit code — `&&` runs the next only on success, `||` only on\
--- failure, `;`/`&` always. A shared return pool lets `//` / `/refs` read earlier\
--- results back. Fully headless-testable.\
---\
--- Pipelines (`|`) and rich reference paths (`/x.y#2`) are not wired yet — bare\
--- `//` and `/Name` references resolve; anything fancier is left for later.\
--- @section Server\
--- @client\
\
local Shell = require(script.Parent.Parent.Parent._Utility.Shell)\
local Context = require(script.Parent.Parent.Parent._Classes.Context)\
local Result = require(script.Parent.Parent.Parent._Patterns.Result)\
\
local Kind = Shell.Token.Kind\
\
local Dispatcher = {}\
Dispatcher.__index = Dispatcher\
\
export type ExecConfig = {\
	executor: any?,\
	realm: string?,\
	sink: ((any) -> ())?,\
	bridge: any?,\
}\
\
export type Config = {\
	--- Optional gate run before a command; return `(false, reason)` to deny.\
	authorize: ((command: any, exec: ExecConfig) -> (boolean, string?))?,\
}\
\
-- operator tokens that separate one command from the next\
local CHAIN_OPS: { [string]: string } = {\
	[Kind.AmpAmp] = \"&&\",\
	[Kind.PipePipe] = \"||\",\
	[Kind.Amp] = \";\",\
	[Kind.Semicolon] = \";\",\
	[Kind.Newline] = \";\",\
}\
\
--- Creates a dispatcher over `registry`.\
function Dispatcher.new(registry: any, config: Config?)\
	return setmetatable({ registry = registry, config = config or {} }, Dispatcher)\
end\
\
-- split the token stream into { op, tokens } segments on chain operators\
local function segment(tokens)\
	local segments = {}\
	local current = { op = nil :: string?, tokens = {} }\
	for _, token in tokens do\
		if token.kind == Kind.EOF then\
			break\
		elseif CHAIN_OPS[token.kind] then\
			table.insert(segments, current)\
			current = { op = CHAIN_OPS[token.kind], tokens = {} }\
		else\
			table.insert(current.tokens, token)\
		end\
	end\
	table.insert(segments, current)\
	return segments\
end\
\
-- the raw string form of an argument token, for the type to transform\
local function rawText(token): string\
	if token.value ~= nil then\
		return tostring(token.value)\
	end\
	return token.text\
end\
\
-- runs one command segment; returns a Result\
function Dispatcher._runSegment(self, tokens, exec, returnPool): any\
	if #tokens == 0 then\
		return Result.ok(nil)\
	end\
	local head = tokens[1]\
	local ctx = Context.new({\
		executor = exec.executor,\
		realm = exec.realm or \"server\",\
		rawText = table.concat((function()\
			local parts = {}\
			for _, t in tokens do\
				table.insert(parts, t.text)\
			end\
			return parts\
		end)(), \" \"),\
		sink = exec.sink,\
		bridge = exec.bridge,\
		returnPool = returnPool,\
	})\
\
	if head.kind ~= Kind.Ident then\
		return ctx:err(`expected a command, got '{head.text}'`)\
	end\
	local command = self.registry:resolve(head.text)\
	if not command then\
		return ctx:err(`unknown command: {head.text}`)\
	end\
\
	if self.config.authorize then\
		local allowed, reason = self.config.authorize(command, exec)\
		if not allowed then\
			return ctx:err(reason or `not allowed to run '{command.name}'`)\
		end\
	end\
\
	-- flags start with their declared defaults\
	for _, flag in command.flags do\
		if flag.hasDefault then\
			ctx.flags[flag.name] = (flag.type.transform(flag.default))\
		end\
	end\
\
	-- walk the tokens after the command name, peeling off flags and refs and\
	-- leaving positional values in rawArgs\
	local rawArgs = {}\
	local index = 2\
	while index <= #tokens do\
		local token = tokens[index]\
		local nextToken = tokens[index + 1]\
\
		if token.kind == Kind.Minus and nextToken and nextToken.kind == Kind.Number and not nextToken.spaceBefore then\
			-- a negative number literal (`-5`), not a flag\
			rawArgs[#rawArgs + 1] = { text = \"-\" .. rawText(nextToken) }\
			index += 2\
		elseif token.kind == Kind.Minus or token.kind == Kind.MinusMinus then\
			if not (nextToken and nextToken.kind == Kind.Ident) then\
				return ctx:err(`expected a flag name after '{token.text}'`)\
			end\
			local flag = command.flagByName[nextToken.text]\
			if not flag then\
				return ctx:err(`unknown flag: {token.text}{nextToken.text}`)\
			end\
			if flag.isBoolean then\
				ctx.flags[flag.name] = true\
				index += 2\
			else\
				local valueToken = tokens[index + 2]\
				if not valueToken or valueToken.kind == Kind.EOF then\
					return ctx:err(`flag --{flag.name} needs a value`)\
				end\
				local value, tErr = flag.type.transform(rawText(valueToken))\
				if tErr then\
					return ctx:err(`flag --{flag.name}: {tErr}`)\
				end\
				local okV, why = flag.type.validate(value)\
				if not okV then\
					return ctx:err(`flag --{flag.name}: {why}`)\
				end\
				ctx.flags[flag.name] = value\
				index += 3\
			end\
		elseif token.kind == Kind.SlashSlash then\
			rawArgs[#rawArgs + 1] = { ref = { last = true, path = {} } }\
			index += 1\
		elseif token.kind == Kind.Slash and nextToken and nextToken.kind == Kind.Ident then\
			rawArgs[#rawArgs + 1] = { ref = { last = false, name = nextToken.text, path = {} } }\
			index += 2\
		else\
			rawArgs[#rawArgs + 1] = { text = rawText(token) }\
			index += 1\
		end\
	end\
\
	-- bind to the declared arguments\
	local bound = {}\
	local count = 0\
	if #command.args == 0 then\
		-- untyped passthrough for arg-less commands\
		for _, raw in rawArgs do\
			count += 1\
			bound[count] = if raw.ref then (returnPool:resolve(raw.ref)) else raw.text\
		end\
	else\
		for i, spec in command.args do\
			local raw = rawArgs[i]\
			count = i\
			if raw == nil then\
				if spec.hasDefault then\
					bound[i] = (spec.type.transform(spec.default))\
				elseif spec.optional then\
					bound[i] = nil\
				else\
					return ctx:err(`missing required argument '{spec.name}'`)\
				end\
			elseif raw.ref then\
				local value, refErr = returnPool:resolve(raw.ref)\
				if refErr then\
					return ctx:err(refErr)\
				end\
				local okValid, why = spec.type.validate(value)\
				if not okValid then\
					return ctx:err(`argument '{spec.name}': {why}`)\
				end\
				bound[i] = value\
			else\
				local value, transformErr = spec.type.transform(raw.text)\
				if transformErr then\
					return ctx:err(`argument '{spec.name}': {transformErr}`)\
				end\
				local okValid, why = spec.type.validate(value)\
				if not okValid then\
					return ctx:err(`argument '{spec.name}': {why}`)\
				end\
				bound[i] = value\
			end\
		end\
	end\
\
	self.registry:fire(\"before\", ctx, command)\
	local okRun, returned = pcall(command.run, ctx, table.unpack(bound, 1, count))\
	local result\
	if not okRun then\
		result = ctx:err(`{command.name} errored: {tostring(returned)}`)\
	elseif Result.is(returned) then\
		result = returned\
	else\
		result = Result.ok(returned)\
	end\
	self.registry:fire(\"after\", ctx, command, result)\
	return result\
end\
\
--- Runs a whole line (with chains). Returns the last executed [[Result]].\
function Dispatcher:run(line: string, exec: ExecConfig?): any\
	local execConfig = exec or {}\
	local lex = Shell.tokenize(line)\
	local segments = segment(lex.tokens)\
	local returnPool = Shell.ReturnPool.new()\
\
	local last = Result.ok(nil)\
	local ran = false\
	for _, seg in segments do\
		if #seg.tokens == 0 then\
			continue\
		end\
		local shouldRun\
		if not ran then\
			shouldRun = true -- the first real command always runs\
		elseif seg.op == \"&&\" then\
			shouldRun = last.code == 0\
		elseif seg.op == \"||\" then\
			shouldRun = last.code ~= 0\
		else -- \";\" / \"&\" / nil\
			shouldRun = true\
		end\
\
		if shouldRun then\
			last = Dispatcher._runSegment(self, seg.tokens, execConfig, returnPool)\
			ran = true\
		end\
	end\
	return last\
end\
\
return Dispatcher\
"},
{"Repl/_Main/Server/Registry","ModuleScript","--- The **Registry** holds every registered command, indexed by name and by\
--- alias, and is the one place a name clash is caught. It parses each definition\
--- through the [[Command]] validator, exposes custom-[[Types|type]] registration,\
--- and keeps the `before`/`after` run hooks the dispatcher fires. Registration\
--- never throws: it returns the collected errors so a bad module fails loudly but\
--- in isolation.\
--- @section Registry\
--- @client\
\
local Command = require(script.Parent.Parent.Parent._Classes.Command)\
local Types = require(script.Parent.Parent.Types)\
\
local Registry = {}\
Registry.__index = Registry\
\
export type Hook = (...any) -> ...any\
\
--- Creates an empty registry.\
function Registry.new()\
	return setmetatable({\
		commands = {} :: { [string]: Command.Command },\
		aliasOf = {} :: { [string]: string }, -- alias/name (lowercased) → canonical name\
		order = {} :: { string }, -- registration order, for stable listing\
		hooks = { before = {} :: { Hook }, after = {} :: { Hook } },\
	}, Registry)\
end\
\
local function key(name: string): string\
	return string.lower(name)\
end\
\
--- Registers a command definition. Returns `(command, errors)`; on any error the\
--- command is *not* registered and `command` is nil.\
function Registry:register(def: Command.Def): (Command.Command?, { string })\
	local result = Command.parse(def)\
	if not result.command then\
		return nil, result.errors\
	end\
	local command = result.command\
	local errors: { string } = {}\
\
	-- collision check across both names and aliases before mutating anything\
	local claimed = { command.name }\
	for _, alias in command.aliases do\
		table.insert(claimed, alias)\
	end\
	for _, token in claimed do\
		local existing = self.aliasOf[key(token)]\
		if existing then\
			table.insert(errors, `'{token}' is already registered by '{existing}'`)\
		end\
	end\
	if #errors > 0 then\
		return nil, errors\
	end\
\
	self.commands[command.name] = command\
	self.aliasOf[key(command.name)] = command.name\
	for _, alias in command.aliases do\
		self.aliasOf[key(alias)] = command.name\
	end\
	table.insert(self.order, command.name)\
	return command, {}\
end\
\
--- Resolves a name or alias (case-insensitive) to its command.\
function Registry:resolve(nameOrAlias: string): Command.Command?\
	local canonical = self.aliasOf[key(nameOrAlias)]\
	return canonical and self.commands[canonical] or nil\
end\
\
--- Every command, in registration order.\
function Registry:all(): { Command.Command }\
	local out = {}\
	for _, name in self.order do\
		table.insert(out, self.commands[name])\
	end\
	return out\
end\
\
--- Registers (or replaces) a custom argument type. Thin passthrough to [[Types]].\
function Registry:registerType(def: Types.Def)\
	Types.register(def)\
end\
\
--- Adds a hook fired `before` or `after` each command runs.\
function Registry:on(phase: \"before\" | \"after\", fn: Hook)\
	local bucket = self.hooks[phase]\
	if not bucket then\
		error(`unknown hook phase '{phase}'`, 2)\
	end\
	table.insert(bucket, fn)\
end\
\
--- Fires every hook registered for `phase`, passing the extra arguments through.\
function Registry:fire(phase: \"before\" | \"after\", ...: any)\
	for _, fn in self.hooks[phase] do\
		fn(...)\
	end\
end\
\
-- ── friendly public names (the DESIGN.md surface) ─────────────────────────────\
\
--- Registers one command definition. Alias of `register`.\
Registry.RegisterCommand = Registry.register\
\
--- Registers a custom argument type under `name`.\
function Registry:RegisterType(name: string, typeDef: any)\
	typeDef = typeDef or {}\
	typeDef.name = name\
	self:registerType(typeDef)\
end\
\
local HOOK_PHASE: { [string]: string } = { BeforeRun = \"before\", AfterRun = \"after\" }\
\
--- Adds a `\"BeforeRun\"` / `\"AfterRun\"` hook.\
function Registry:RegisterHook(phase: string, fn: Hook)\
	self:on(HOOK_PHASE[phase] or phase, fn)\
end\
\
--- A named, shared table for cross-command state (created on first use).\
function Registry:GetStore(name: string): { [any]: any }\
	self._stores = self._stores or {}\
	self._stores[name] = self._stores[name] or {}\
	return self._stores[name]\
end\
\
return Registry\
"},
{"Repl/_Main/Types","ModuleScript","--- The **type engine**. A type is a small record with three jobs: `transform`\
--- turns raw text into a value, `validate` checks a value, and `autocomplete`\
--- offers completions for a partial input. The engine ships primitive types and\
--- compiles a [[Expr|type expression]] (`Player | Character`, `Number & Int32`,\
--- `2 < Integer < 30`) into a single composed type — unions merge completions,\
--- intersections stack constraints, and a bounded range *enumerates* its valid\
--- values so the command bar can suggest them.\
--- @section Types\
--- @client\
\
local Expr = require(script.Expr)\
\
local Types = {}\
\
--- A resolved, ready-to-use type.\
export type Type = {\
	name: string,\
	optional: boolean?,\
	--- Raw text → `(value, nil)` or `(nil, error)`.\
	transform: (raw: string) -> (any, string?),\
	--- A value → `(ok, reason?)`.\
	validate: (value: any) -> (boolean, string?),\
	--- A partial input → completion strings.\
	autocomplete: (prefix: string) -> { string },\
}\
\
--- A type definition you register. Only `name` and `transform` are required;\
--- the rest have sensible defaults.\
export type Def = {\
	name: string,\
	transform: ((raw: string) -> (any, string?))?,\
	validate: ((value: any) -> (boolean, string?))?,\
	autocomplete: ((prefix: string) -> { string })?,\
	--- Marks a whole-number type so ranges over it enumerate integers.\
	integer: boolean?,\
}\
\
local ENUM_CAP = 60 -- never suggest more than this many range values\
\
local registry: { [string]: Def } = {}\
\
local function identity(raw: string): (any, string?)\
	return raw, nil\
end\
local function alwaysValid(): (boolean, string?)\
	return true\
end\
local function noCompletions(): { string }\
	return {}\
end\
\
--- Registers (or replaces) a type definition.\
function Types.register(def: Def)\
	registry[def.name] = def\
end\
\
--- Returns the raw definition registered under `name`, if any.\
function Types.get(name: string): Def?\
	return registry[name]\
end\
\
-- ── built-in primitives ─────────────────────────────────────────────────────\
\
Types.register({\
	name = \"String\",\
	transform = identity,\
	validate = function(v)\
		return type(v) == \"string\", if type(v) == \"string\" then nil else \"expected a string\"\
	end,\
})\
\
Types.register({\
	name = \"Number\",\
	transform = function(raw)\
		local n = tonumber(raw)\
		if n == nil then\
			return nil, `'{raw}' is not a number`\
		end\
		return n\
	end,\
	validate = function(v)\
		return type(v) == \"number\", if type(v) == \"number\" then nil else \"expected a number\"\
	end,\
})\
\
Types.register({\
	name = \"Integer\",\
	integer = true,\
	transform = function(raw)\
		local n = tonumber(raw)\
		if n == nil then\
			return nil, `'{raw}' is not a number`\
		end\
		if n % 1 ~= 0 then\
			return nil, `'{raw}' is not a whole number`\
		end\
		return n\
	end,\
	validate = function(v)\
		if type(v) ~= \"number\" then\
			return false, \"expected a number\"\
		end\
		return v % 1 == 0, if v % 1 == 0 then nil else \"expected a whole number\"\
	end,\
})\
\
Types.register({\
	name = \"Boolean\",\
	transform = function(raw)\
		local low = string.lower(raw)\
		if low == \"true\" or low == \"yes\" or low == \"y\" or low == \"1\" then\
			return true\
		elseif low == \"false\" or low == \"no\" or low == \"n\" or low == \"0\" then\
			return false\
		end\
		return nil, `'{raw}' is not true/false`\
	end,\
	validate = function(v)\
		return type(v) == \"boolean\", if type(v) == \"boolean\" then nil else \"expected a boolean\"\
	end,\
	autocomplete = function(prefix)\
		local out = {}\
		for _, word in { \"true\", \"false\" } do\
			if string.sub(word, 1, #prefix) == prefix then\
				table.insert(out, word)\
			end\
		end\
		return out\
	end,\
})\
\
-- ── compilation ─────────────────────────────────────────────────────────────\
\
local compileNode: (node: any) -> Type\
\
local function unknownType(name: string): Type\
	return {\
		name = name,\
		transform = function()\
			return nil, `unknown type '{name}'`\
		end,\
		validate = function()\
			return false, `unknown type '{name}'`\
		end,\
		autocomplete = noCompletions,\
	}\
end\
\
-- a literal string value: `name: gruvbox | tokyonight` is a union of these, i.e.\
-- an enum of allowed words that also autocompletes itself\
local function literalType(value: string): Type\
	return {\
		name = value,\
		transform = function(raw)\
			if raw == value then\
				return value\
			end\
			return nil, `expected '{value}'`\
		end,\
		validate = function(v)\
			return v == value, if v == value then nil else `expected '{value}'`\
		end,\
		autocomplete = function(prefix)\
			if string.sub(value, 1, #prefix) == prefix then\
				return { value }\
			end\
			return {}\
		end,\
	}\
end\
\
local function compileName(node: any): Type\
	local def = registry[node.name]\
	if not def then\
		-- an unregistered name is a literal value, so `gruvbox | tokyonight` and\
		-- `red | green | blue` work as enums with no type registration\
		return literalType(node.name)\
	end\
	return {\
		name = def.name,\
		transform = def.transform or identity,\
		validate = def.validate or alwaysValid,\
		autocomplete = def.autocomplete or noCompletions,\
	}\
end\
\
-- is the innermost atom a whole-number type? (so a range enumerates integers)\
local function innerIsInteger(node: any): boolean\
	if node.kind == \"Name\" then\
		local def = registry[node.name]\
		return def ~= nil and def.integer == true\
	elseif node.kind == \"Range\" then\
		return innerIsInteger(node.inner)\
	elseif node.kind == \"Intersection\" then\
		for _, part in node.parts do\
			if innerIsInteger(part) then\
				return true\
			end\
		end\
	end\
	return false\
end\
\
local function compileRange(node: any): Type\
	local inner = compileNode(node.inner)\
	local min, minInc, max, maxInc = node.min, node.minInc, node.max, node.maxInc\
	local isInt = innerIsInteger(node.inner)\
\
	local function boundsText(): string\
		local lo = if min ~= nil then `{min}{if minInc then \" ≤\" else \" <\"}` else \"\"\
		local hi = if max ~= nil then `{if maxInc then \"≤ \" else \"< \"}{max}` else \"\"\
		return `{lo} {inner.name} {hi}`\
	end\
\
	local function inRange(v: number): (boolean, string?)\
		if min ~= nil then\
			if minInc and v < min then\
				return false, `must be ≥ {min}`\
			elseif not minInc and v <= min then\
				return false, `must be > {min}`\
			end\
		end\
		if max ~= nil then\
			if maxInc and v > max then\
				return false, `must be ≤ {max}`\
			elseif not maxInc and v >= max then\
				return false, `must be < {max}`\
			end\
		end\
		return true\
	end\
\
	return {\
		name = boundsText(),\
		transform = inner.transform,\
		validate = function(v)\
			local ok, why = inner.validate(v)\
			if not ok then\
				return false, why\
			end\
			if type(v) ~= \"number\" then\
				return false, \"expected a number\"\
			end\
			return inRange(v)\
		end,\
		autocomplete = function(prefix)\
			-- enumerate only a fully-bounded integer range; otherwise nothing useful\
			if not isInt or min == nil or max == nil then\
				return {}\
			end\
			local lo = if minInc then math.ceil(min) else math.floor(min) + 1\
			local hi = if maxInc then math.floor(max) else math.ceil(max) - 1\
			local out = {}\
			for value = lo, hi do\
				if #out >= ENUM_CAP then\
					break\
				end\
				local text = tostring(value)\
				if string.sub(text, 1, #prefix) == prefix then\
					table.insert(out, text)\
				end\
			end\
			return out\
		end,\
	}\
end\
\
local function dedupe(list: { string }): { string }\
	local seen, out = {}, {}\
	for _, item in list do\
		if not seen[item] then\
			seen[item] = true\
			table.insert(out, item)\
		end\
	end\
	return out\
end\
\
local function compileUnion(node: any): Type\
	local options = {}\
	local names = {}\
	for _, opt in node.options do\
		local t = compileNode(opt)\
		table.insert(options, t)\
		table.insert(names, t.name)\
	end\
	return {\
		name = table.concat(names, \" | \"),\
		transform = function(raw)\
			local firstErr\
			for _, opt in options do\
				local value, err = opt.transform(raw)\
				if err == nil then\
					local ok = opt.validate(value)\
					if ok then\
						return value\
					end\
				end\
				firstErr = firstErr or err\
			end\
			return nil, firstErr or `'{raw}' matched no option`\
		end,\
		validate = function(v)\
			for _, opt in options do\
				if opt.validate(v) then\
					return true\
				end\
			end\
			return false, `matched none of {table.concat(names, \" | \")}`\
		end,\
		autocomplete = function(prefix)\
			local out = {}\
			for _, opt in options do\
				for _, s in opt.autocomplete(prefix) do\
					table.insert(out, s)\
				end\
			end\
			return dedupe(out)\
		end,\
	}\
end\
\
local function compileIntersection(node: any): Type\
	local parts = {}\
	local names = {}\
	for _, p in node.parts do\
		local t = compileNode(p)\
		table.insert(parts, t)\
		table.insert(names, t.name)\
	end\
	return {\
		name = table.concat(names, \" & \"),\
		transform = parts[1].transform, -- the first part reads the value; the rest constrain it\
		validate = function(v)\
			for _, part in parts do\
				local ok, why = part.validate(v)\
				if not ok then\
					return false, why\
				end\
			end\
			return true\
		end,\
		autocomplete = function(prefix)\
			-- the first part's completions, kept only if they satisfy the rest\
			local out = {}\
			for _, s in parts[1].autocomplete(prefix) do\
				local value, err = parts[1].transform(s)\
				local keep = err == nil\
				if keep then\
					for i = 2, #parts do\
						if not parts[i].validate(value) then\
							keep = false\
							break\
						end\
					end\
				end\
				if keep then\
					table.insert(out, s)\
				end\
			end\
			return out\
		end,\
	}\
end\
\
function compileNode(node: any): Type\
	if node == nil then\
		return unknownType(\"?\")\
	elseif node.kind == \"Name\" then\
		return compileName(node)\
	elseif node.kind == \"Range\" then\
		return compileRange(node)\
	elseif node.kind == \"Union\" then\
		return compileUnion(node)\
	elseif node.kind == \"Intersection\" then\
		return compileIntersection(node)\
	end\
	return unknownType(node.kind or \"?\")\
end\
\
--- Compiles a type-expression string into a resolved [[Type]]. On a parse error\
--- the returned type rejects everything, and the messages are in `.parseErrors`.\
function Types.compile(source: string): Type & { parseErrors: { string } }\
	local parsed = Expr.parse(source)\
	if parsed.ast == nil or #parsed.errors > 0 then\
		local bad: any = {\
			name = source,\
			optional = parsed.optional,\
			parseErrors = parsed.errors,\
			transform = function()\
				return nil, `invalid type '{source}'`\
			end,\
			validate = function()\
				return false, `invalid type '{source}'`\
			end,\
			autocomplete = noCompletions,\
		}\
		return bad\
	end\
	local resolved: any = compileNode(parsed.ast)\
	resolved.optional = parsed.optional\
	resolved.parseErrors = parsed.errors\
	return resolved\
end\
\
return Types\
"},
{"Repl/_Main/Types/Expr","ModuleScript","--- Parses a **type expression** — the text after the colon in an `Args` entry —\
--- into a small AST the [[Types]] engine compiles. This is what makes\
--- `Player | Character`, `Number & Int32`, and `2 < Number < 30` real.\
---\
--- Grammar (low → high precedence):\
--- `Union(|) → Intersection(&) → Range(bounded atom) → Atom(Name | \"(\" expr \")\")`.\
--- A trailing `?` on the whole expression marks the argument optional.\
--- @section Types\
--- @client\
\
local Expr = {}\
\
export type Node = any -- { kind: \"Union\"|\"Intersection\"|\"Range\"|\"Name\", ... }\
\
export type ParseResult = {\
	ast: Node?,\
	optional: boolean,\
	errors: { string },\
}\
\
type Tok = { t: string, v: any }\
\
local COMPARE: { [string]: boolean } = { [\"<\"] = true, [\">\"] = true, [\"<=\"] = true, [\">=\"] = true }\
\
local function tokenize(source: string): { Tok }\
	local toks: { Tok } = {}\
	local i, n = 1, #source\
	while i <= n do\
		local c = string.sub(source, i, i)\
		if string.match(c, \"%s\") then\
			i += 1\
		elseif c == \"|\" or c == \"&\" or c == \"(\" or c == \")\" or c == \"?\" then\
			table.insert(toks, { t = c })\
			i += 1\
		elseif c == \"<\" or c == \">\" then\
			if string.sub(source, i + 1, i + 1) == \"=\" then\
				table.insert(toks, { t = c .. \"=\" })\
				i += 2\
			else\
				table.insert(toks, { t = c })\
				i += 1\
			end\
		elseif string.match(c, \"%d\") or (c == \"-\" and string.match(string.sub(source, i + 1, i + 1), \"%d\")) then\
			local j = if c == \"-\" then i + 1 else i\
			while j <= n and string.match(string.sub(source, j, j), \"[%d%.]\") do\
				j += 1\
			end\
			table.insert(toks, { t = \"num\", v = tonumber(string.sub(source, i, j - 1)) })\
			i = j\
		elseif string.match(c, \"[%a_]\") then\
			local j = i\
			while j <= n and string.match(string.sub(source, j, j), \"[%w_]\") do\
				j += 1\
			end\
			table.insert(toks, { t = \"name\", v = string.sub(source, i, j - 1) })\
			i = j\
		else\
			i += 1 -- lenient: skip anything unrecognized\
		end\
	end\
	table.insert(toks, { t = \"eof\" })\
	return toks\
end\
\
--- Parses a type-expression string. Never throws; returns the AST (or nil),\
--- whether the argument is optional (trailing `?`), and any errors.\
function Expr.parse(source: string): ParseResult\
	local toks = tokenize(source)\
	local pos = 1\
	local errors: { string } = {}\
\
	local function cur(): Tok\
		return toks[pos]\
	end\
	local function at(t: string): boolean\
		return toks[pos].t == t\
	end\
	local function advance(): Tok\
		local tok = toks[pos]\
		if tok.t ~= \"eof\" then\
			pos += 1\
		end\
		return tok\
	end\
	local function err(message: string)\
		table.insert(errors, message)\
	end\
\
	local parseUnion, parseIntersection, parseConstrained, parseAtom\
\
	function parseAtom(): Node?\
		if at(\"(\") then\
			advance()\
			local inner = parseUnion()\
			if at(\")\") then\
				advance()\
			else\
				err(\"expected ')'\")\
			end\
			return inner\
		elseif at(\"name\") then\
			local nameTok = advance()\
			return { kind = \"Name\", name = nameTok.v }\
		end\
		err(`unexpected '{cur().t}' in a type`)\
		if not at(\"eof\") then\
			advance()\
		end\
		return nil\
	end\
\
	-- a bounded atom: [num op] atom [op num]  (a range/conditional), else the atom\
	function parseConstrained(): Node?\
		local leadNum, leadOp\
		if at(\"num\") then\
			leadNum = advance().v\
			if COMPARE[cur().t] then\
				leadOp = advance().t\
			else\
				err(\"expected a comparison after the bound\")\
			end\
		end\
		local atom = parseAtom()\
		local trailOp, trailNum\
		if COMPARE[cur().t] then\
			trailOp = advance().t\
			if at(\"num\") then\
				trailNum = advance().v\
			else\
				err(\"expected a number after the comparison\")\
			end\
		end\
		if leadNum == nil and trailNum == nil then\
			return atom\
		end\
		local node: any = { kind = \"Range\", inner = atom }\
		-- lead:  leadNum <op> atom\
		if leadNum ~= nil and leadOp then\
			if leadOp == \"<\" then\
				node.min, node.minInc = leadNum, false\
			elseif leadOp == \"<=\" then\
				node.min, node.minInc = leadNum, true\
			elseif leadOp == \">\" then\
				node.max, node.maxInc = leadNum, false\
			elseif leadOp == \">=\" then\
				node.max, node.maxInc = leadNum, true\
			end\
		end\
		-- trail:  atom <op> trailNum\
		if trailNum ~= nil and trailOp then\
			if trailOp == \"<\" then\
				node.max, node.maxInc = trailNum, false\
			elseif trailOp == \"<=\" then\
				node.max, node.maxInc = trailNum, true\
			elseif trailOp == \">\" then\
				node.min, node.minInc = trailNum, false\
			elseif trailOp == \">=\" then\
				node.min, node.minInc = trailNum, true\
			end\
		end\
		return node\
	end\
\
	function parseIntersection(): Node?\
		local left = parseConstrained()\
		if not at(\"&\") then\
			return left\
		end\
		local parts = { left }\
		while at(\"&\") do\
			advance()\
			table.insert(parts, parseConstrained())\
		end\
		return { kind = \"Intersection\", parts = parts }\
	end\
\
	function parseUnion(): Node?\
		local left = parseIntersection()\
		if not at(\"|\") then\
			return left\
		end\
		local options = { left }\
		while at(\"|\") do\
			advance()\
			table.insert(options, parseIntersection())\
		end\
		return { kind = \"Union\", options = options }\
	end\
\
	local ast = parseUnion()\
	local optional = false\
	if at(\"?\") then\
		advance()\
		optional = true\
	end\
	if not at(\"eof\") then\
		err(`trailing '{cur().t}' in a type`)\
	end\
	return { ast = ast, optional = optional, errors = errors }\
end\
\
return Expr\
"},
