{"Repl/_Classes/Argument","ModuleScript","--- Parses the terse **Args DSL** — one `\"name: TypeExpr = default\"` string per\
--- argument — into structured specs. The text after the colon is a real\
--- [[Types|type expression]] (so `amount: Integer? = 1` and `n: 2 < Integer < 30`\
--- both work); the type is compiled here so the handler receives typed, validated\
--- values. Never throws; problems land in each spec's `.error`.\
--- @section Registry\
--- @client\
\
local Types = require(script.Parent.Parent._Main.Types)\
\
local Argument = {}\
\
export type Spec = {\
	name: string,\
	typeExpr: string,\
	type: Types.Type,\
	optional: boolean,\
	hasDefault: boolean,\
	default: string?, -- the raw default text, transformed by `type` at dispatch\
	error: string?,\
}\
\
local function trim(s: string): string\
	return (string.gsub(s, \"^%s*(.-)%s*$\", \"%1\"))\
end\
\
-- Find the `=` that separates a default from the type, skipping the `=` inside\
-- the comparison operators `<=` / `>=` that a range expression may contain.\
local function findDefaultEq(rest: string): number?\
	for p = 1, #rest do\
		if string.sub(rest, p, p) == \"=\" then\
			local prev = string.sub(rest, p - 1, p - 1)\
			if prev ~= \"<\" and prev ~= \">\" and prev ~= \"=\" then\
				return p\
			end\
		end\
	end\
	return nil\
end\
\
--- Parses a single `\"name: TypeExpr = default\"` entry.\
function Argument.parse(spec: string): Spec\
	local name, rest = string.match(spec, \"^%s*([%a_][%w_]*)%s*:%s*(.+)$\")\
	if not name then\
		local bare = string.match(spec, \"^%s*([%a_][%w_]*)\") or trim(spec)\
		return {\
			name = bare,\
			typeExpr = \"\",\
			type = Types.compile(\"\"),\
			optional = false,\
			hasDefault = false,\
			default = nil,\
			error = `expected 'name: Type' but got '{trim(spec)}'`,\
		}\
	end\
\
	local typeExpr, default = rest, nil\
	local eq = findDefaultEq(rest)\
	if eq then\
		typeExpr = string.sub(rest, 1, eq - 1)\
		default = trim(string.sub(rest, eq + 1))\
	end\
	typeExpr = trim(typeExpr)\
\
	local ty = Types.compile(typeExpr)\
	local errParts = (ty :: any).parseErrors\
	local err\
	if errParts and #errParts > 0 then\
		err = `bad type '{typeExpr}': {table.concat(errParts, \"; \")}`\
	elseif default ~= nil then\
		-- a default must itself pass the type\
		local value, transformErr = ty.transform(default)\
		if transformErr ~= nil then\
			err = `default '{default}' is invalid: {transformErr}`\
		else\
			local ok, why = ty.validate(value)\
			if not ok then\
				err = `default '{default}' is invalid: {why}`\
			end\
		end\
	end\
\
	return {\
		name = name,\
		typeExpr = typeExpr,\
		type = ty,\
		optional = ty.optional == true or default ~= nil,\
		hasDefault = default ~= nil,\
		default = default,\
		error = err,\
	}\
end\
\
--- Parses a whole `Args` list, collecting per-entry errors plus one structural\
--- rule: a required argument may not follow an optional one.\
function Argument.parseList(specs: { string }): ({ Spec }, { string })\
	local out: { Spec } = {}\
	local errors: { string } = {}\
	local seenOptional = false\
	for index, raw in specs do\
		local spec = Argument.parse(raw)\
		if spec.error then\
			table.insert(errors, `arg #{index} ({spec.name}): {spec.error}`)\
		end\
		if spec.optional then\
			seenOptional = true\
		elseif seenOptional then\
			table.insert(errors, `arg #{index} ({spec.name}): a required argument cannot follow an optional one`)\
		end\
		table.insert(out, spec)\
	end\
	return out, errors\
end\
\
return Argument\
"},
{"Repl/_Classes/Command","ModuleScript","--- Validates and normalizes a **command definition** — the table a user returns\
--- from a command module — into a checked record. Names are validated, the\
--- [[Argument|Args DSL]] is parsed, and every problem is collected (never\
--- thrown) so the [[Registry]] can report a whole module's mistakes at once.\
--- @section Registry\
--- @client\
\
local Argument = require(script.Parent.Argument)\
\
local Command = {}\
\
export type Confirm = string | { message: string?, type: (\"y/n\" | \"phrase\")?, phrase: string? }\
\
export type Def = {\
	Name: string,\
	Aliases: { string }?,\
	Description: string?,\
	Capabilities: { string }?,\
	Args: { string }?,\
	Confirm: Confirm?,\
	Run: (...any) -> ...any,\
}\
\
export type Command = {\
	name: string,\
	aliases: { string },\
	description: string,\
	capabilities: { string },\
	args: { Argument.Spec },\
	confirm: Confirm?,\
	run: (...any) -> ...any,\
}\
\
export type Result = {\
	command: Command?,\
	errors: { string },\
}\
\
local NAME_PATTERN = \"^[%a_][%w_%-]*$\" -- letters/underscore, then word chars or dashes\
\
local function isStringArray(value: any): boolean\
	if type(value) ~= \"table\" then\
		return false\
	end\
	for _, item in value do\
		if type(item) ~= \"string\" then\
			return false\
		end\
	end\
	return true\
end\
\
--- Parses and validates a command definition table.\
function Command.parse(def: Def): Result\
	local errors: { string } = {}\
	local function fail(message: string)\
		table.insert(errors, message)\
	end\
\
	if type(def) ~= \"table\" then\
		return { command = nil, errors = { \"command definition must be a table\" } }\
	end\
\
	local name = def.Name\
	if type(name) ~= \"string\" or not string.match(name, NAME_PATTERN) then\
		fail(`Name must be a valid identifier, got {tostring(name)}`)\
		name = tostring(name)\
	end\
\
	local aliases: { string } = {}\
	if def.Aliases ~= nil then\
		if isStringArray(def.Aliases) then\
			for _, alias in def.Aliases :: { string } do\
				if not string.match(alias, NAME_PATTERN) then\
					fail(`alias '{alias}' is not a valid identifier`)\
				else\
					table.insert(aliases, alias)\
				end\
			end\
		else\
			fail(\"Aliases must be an array of strings\")\
		end\
	end\
\
	if def.Capabilities ~= nil and not isStringArray(def.Capabilities) then\
		fail(\"Capabilities must be an array of strings\")\
	end\
\
	local args: { Argument.Spec } = {}\
	if def.Args ~= nil then\
		if isStringArray(def.Args) then\
			local parsed, argErrors = Argument.parseList(def.Args :: { string })\
			args = parsed\
			for _, message in argErrors do\
				fail(message)\
			end\
		else\
			fail(\"Args must be an array of DSL strings\")\
		end\
	end\
\
	if type(def.Run) ~= \"function\" then\
		fail(\"Run must be a function\")\
	end\
\
	if #errors > 0 then\
		return { command = nil, errors = errors }\
	end\
\
	return {\
		command = {\
			name = name,\
			aliases = aliases,\
			description = def.Description or \"\",\
			capabilities = (def.Capabilities :: { string }?) or {},\
			args = args,\
			confirm = def.Confirm,\
			run = def.Run,\
		},\
		errors = errors,\
	}\
end\
\
return Command\
"},
{"Repl/_Classes/Context","ModuleScript","--- The **Context** (`ctx`) handed to every command handler: it is how a command\
--- talks back to the terminal. Output methods emit structured [[Output]] nodes;\
--- `ok`/`err`/`abort` both report *and* return a [[Result]] with the right exit\
--- code; `returns` records a value in the [[ReturnPool]] for later `/references`;\
--- `store` is a per-session scratch space. Interactive calls (`confirm`, `prompt`,\
--- `choose`, `exec`) delegate to an injected bridge — headless in tests, a real\
--- client round-trip once Network is in.\
--- @section Context\
--- @client\
\
local Output = require(script.Parent.Parent._Utility.Render.Output)\
local Result = require(script.Parent.Parent._Patterns.Result)\
local ReturnPool = require(script.Parent.Parent._Utility.Shell.ReturnPool)\
\
local Context = {}\
Context.__index = Context\
\
export type Bridge = {\
	confirm: ((message: string) -> boolean)?,\
	prompt: ((message: string, default: string?) -> string?)?,\
	choose: ((message: string, options: { string }) -> string?)?,\
	exec: ((name: string, ...any) -> any)?,\
}\
\
export type Config = {\
	executor: any?,\
	rawText: string?,\
	args: { any }?,\
	realm: string?,\
	returnPool: any?,\
	sink: ((Output.Node) -> ())?,\
	bridge: Bridge?,\
}\
\
--- Creates a context. Everything is optional; a fresh ReturnPool and an empty\
--- store are provided if you don't pass them.\
function Context.new(config: Config?)\
	local cfg = config or {}\
	return setmetatable({\
		executor = cfg.executor,\
		rawText = cfg.rawText or \"\",\
		args = cfg.args or {},\
		realm = cfg.realm or \"server\",\
		returnPool = cfg.returnPool or ReturnPool.new(),\
		output = {} :: { Output.Node }, -- every emitted node, in order\
		_sink = cfg.sink,\
		_store = {} :: { [string]: any },\
		_bridge = cfg.bridge,\
	}, Context)\
end\
\
--- Emits a node: records it and forwards it to the sink (the live terminal).\
function Context:emit(node: Output.Node): Output.Node\
	table.insert(self.output, node)\
	if self._sink then\
		self._sink(node)\
	end\
	return node\
end\
\
-- ── output ──────────────────────────────────────────────────────────────────\
\
--- A neutral reply line.\
function Context:reply(text: string)\
	return self:emit(Output.plain(text))\
end\
function Context:success(text: string)\
	return self:emit(Output.success(text))\
end\
function Context:error(text: string)\
	return self:emit(Output.error(text))\
end\
function Context:warn(text: string)\
	return self:emit(Output.warn(text))\
end\
function Context:info(text: string)\
	return self:emit(Output.info(text))\
end\
function Context:message(text: string)\
	return self:emit(Output.message(text))\
end\
\
--- A line in an arbitrary theme color token.\
function Context:custom(color: string, text: string)\
	return self:emit(Output.line(\"plain\", { Output.segment(text, { color = color }) }))\
end\
\
--- A line prefixed with a Lucide icon.\
function Context:icon(name: string, text: string)\
	return self:emit(Output.line(\"plain\", { Output.segment(text, { icon = name }) }))\
end\
\
--- An aligned table block from rows of cells.\
function Context:table(rows: { { string } })\
	return self:emit(Output.table(rows))\
end\
\
--- A multi-line ascii block (split on newlines).\
function Context:ascii(text: string)\
	local lines: { Output.Line } = {}\
	for line in string.gmatch(text .. \"\\n\", \"(.-)\\n\") do\
		table.insert(lines, Output.plain(line))\
	end\
	return self:emit(Output.block(\"ascii\", lines))\
end\
\
-- ── outcomes (report + return a Result) ──────────────────────────────────────\
\
--- Reports success (if a message is given) and returns an ok [[Result]].\
function Context:ok(message: any?): Result.Result\
	if message ~= nil then\
		self:success(tostring(message))\
	end\
	return Result.ok(message)\
end\
\
--- Reports an error and returns an err [[Result]] (exit code defaults to 1).\
function Context:err(message: string?, code: number?): Result.Result\
	if message ~= nil then\
		self:error(tostring(message))\
	end\
	return Result.err(message or \"error\", code)\
end\
\
--- Reports a cancellation and returns an abort [[Result]] (exit code 130).\
function Context:abort(reason: string?): Result.Result\
	if reason ~= nil then\
		self:message(tostring(reason))\
	end\
	return Result.abort(reason)\
end\
\
-- ── return pool ───────────────────────────────────────────────────────────--\
\
--- Records `value` in the return pool so later `/references` can read it back.\
function Context:returns(value: any, valueType: string?, label: string?): any\
	self.returnPool:push(value, valueType, label)\
	return value\
end\
\
-- ── session store ─────────────────────────────────────────────────────────--\
\
--- `store(name)` reads; `store(name, value)` writes (and returns the value).\
function Context:store(name: string, ...: any): any\
	if select(\"#\", ...) > 0 then\
		local value = ...\
		self._store[name] = value\
		return value\
	end\
	return self._store[name]\
end\
\
-- ── interactive (delegated to the bridge) ────────────────────────────────────\
\
local function bridged(self, method: string)\
	local bridge = self._bridge\
	if not bridge or not bridge[method] then\
		error(`ctx:{method} is not available in this context`, 3)\
	end\
	return bridge[method]\
end\
\
--- Asks a yes/no question; blocks the terminal until answered.\
function Context:confirm(message: string): boolean\
	return bridged(self, \"confirm\")(message)\
end\
\
--- Prompts for a line of text (optionally with a default).\
function Context:prompt(message: string, default: string?): string?\
	return bridged(self, \"prompt\")(message, default)\
end\
\
--- Presents a choice between `options`.\
function Context:choose(message: string, options: { string }): string?\
	return bridged(self, \"choose\")(message, options)\
end\
\
--- Runs another command by name from inside this one.\
function Context:exec(name: string, ...: any): any\
	return bridged(self, \"exec\")(name, ...)\
end\
\
return Context\
"},
