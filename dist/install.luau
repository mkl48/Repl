					kind = Kind.Slash\
				elseif b == 46 then\
					kind = Kind.Dot\
				elseif b == 35 then\
					kind = Kind.Hash\
				elseif b == 64 then\
					kind = Kind.At\
				elseif b == 61 then\
					kind = Kind.Assign\
				elseif b == 33 then\
					kind = Kind.Bang\
				elseif b == 126 then\
					kind = Kind.Tilde\
				elseif b == 38 then\
					kind = Kind.Amp\
				elseif b == 124 then\
					kind = Kind.Pipe\
				elseif b == 59 then\
					kind = Kind.Semicolon\
				elseif b == 62 then\
					kind = Kind.Gt\
				elseif b == 60 then\
					kind = Kind.Lt\
				elseif b == 43 then\
					kind = Kind.Plus\
				elseif b == 45 then\
					kind = Kind.Minus\
				elseif b == 42 then\
					kind = Kind.Star\
				elseif b == 37 then\
					kind = Kind.Percent\
				elseif b == 40 then\
					kind = Kind.LParen\
				elseif b == 41 then\
					kind = Kind.RParen\
				elseif b == 123 then\
					kind = Kind.LBrace\
				elseif b == 125 then\
					kind = Kind.RBrace\
				elseif b == 91 then\
					kind = Kind.LBracket\
				elseif b == 93 then\
					kind = Kind.RBracket\
				end\
