local function getTweenDuration(\
	tweenInfo: TweenInfo\
): number\
	if tweenInfo.RepeatCount <= -1 then\
		return math.huge\
	end\
	local tweenDuration = tweenInfo.DelayTime + tweenInfo.Time\
	if tweenInfo.Reverses then\
		tweenDuration += tweenInfo.Time\
	end\
