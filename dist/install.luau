	if External.isTimeCritical() then\
		return \"unsure\"\
	elseif scopeA == scopeB then\
		local scopeA: {unknown} = scopeA\
		for index = #scopeA, 1, -1 do\
			local value = scopeA[index]\
			if value == a then\
				return \"definitely-b\"\
			elseif value == b then\
				return \"definitely-a\"\
			end\
		end\
		return \"unsure\"\
	else\
		return whichScopeLivesLonger(scopeA, scopeB)\
	end\
