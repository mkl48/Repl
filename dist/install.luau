{"Repl/_Main/Server/Registry","ModuleScript","--- The **Registry** holds every registered command, indexed by name and by\
--- alias, and is the one place a name clash is caught. It parses each definition\
--- through the [[Command]] validator, exposes custom-[[Types|type]] registration,\
--- and keeps the `before`/`after` run hooks the dispatcher fires. Registration\
--- never throws: it returns the collected errors so a bad module fails loudly but\
--- in isolation.\
--- @section Registry\
--- @client\
\
local Command = require(script.Parent.Parent.Parent._Classes.Command)\
local Types = require(script.Parent.Parent.Types)\
\
local Registry = {}\
Registry.__index = Registry\
\
export type Hook = (...any) -> ...any\
\
--- Creates an empty registry.\
function Registry.new()\
	return setmetatable({\
		commands = {} :: { [string]: Command.Command },\
		aliasOf = {} :: { [string]: string }, -- alias/name (lowercased) → canonical name\
		order = {} :: { string }, -- registration order, for stable listing\
		hooks = { before = {} :: { Hook }, after = {} :: { Hook } },\
	}, Registry)\
end\
\
local function key(name: string): string\
	return string.lower(name)\
end\
\
--- Registers a command definition. Returns `(command, errors)`; on any error the\
--- command is *not* registered and `command` is nil.\
function Registry:register(def: Command.Def): (Command.Command?, { string })\
	local result = Command.parse(def)\
	if not result.command then\
		return nil, result.errors\
	end\
	local command = result.command\
	local errors: { string } = {}\
\
	-- collision check across both names and aliases before mutating anything\
	local claimed = { command.name }\
	for _, alias in command.aliases do\
		table.insert(claimed, alias)\
	end\
	for _, token in claimed do\
		local existing = self.aliasOf[key(token)]\
		if existing then\
			table.insert(errors, `'{token}' is already registered by '{existing}'`)\
		end\
	end\
	if #errors > 0 then\
		return nil, errors\
	end\
\
	self.commands[command.name] = command\
	self.aliasOf[key(command.name)] = command.name\
	for _, alias in command.aliases do\
		self.aliasOf[key(alias)] = command.name\
	end\
	table.insert(self.order, command.name)\
	return command, {}\
end\
\
--- Resolves a name or alias (case-insensitive) to its command.\
function Registry:resolve(nameOrAlias: string): Command.Command?\
	local canonical = self.aliasOf[key(nameOrAlias)]\
	return canonical and self.commands[canonical] or nil\
end\
\
--- Every command, in registration order.\
function Registry:all(): { Command.Command }\
	local out = {}\
	for _, name in self.order do\
		table.insert(out, self.commands[name])\
	end\
	return out\
end\
\
--- Registers (or replaces) a custom argument type. Thin passthrough to [[Types]].\
function Registry:registerType(def: Types.Def)\
	Types.register(def)\
end\
\
--- Adds a hook fired `before` or `after` each command runs.\
function Registry:on(phase: \"before\" | \"after\", fn: Hook)\
	local bucket = self.hooks[phase]\
	if not bucket then\
		error(`unknown hook phase '{phase}'`, 2)\
	end\
	table.insert(bucket, fn)\
end\
\
--- Fires every hook registered for `phase`, passing the extra arguments through.\
function Registry:fire(phase: \"before\" | \"after\", ...: any)\
	for _, fn in self.hooks[phase] do\
		fn(...)\
	end\
end\
\
return Registry\
"},
{"Repl/_Main/Types","ModuleScript","--- The **type engine**. A type is a small record with three jobs: `transform`\
--- turns raw text into a value, `validate` checks a value, and `autocomplete`\
--- offers completions for a partial input. The engine ships primitive types and\
--- compiles a [[Expr|type expression]] (`Player | Character`, `Number & Int32`,\
--- `2 < Integer < 30`) into a single composed type — unions merge completions,\
--- intersections stack constraints, and a bounded range *enumerates* its valid\
--- values so the command bar can suggest them.\
--- @section Types\
--- @client\
\
local Expr = require(script.Expr)\
\
local Types = {}\
\
--- A resolved, ready-to-use type.\
export type Type = {\
	name: string,\
	optional: boolean?,\
	--- Raw text → `(value, nil)` or `(nil, error)`.\
	transform: (raw: string) -> (any, string?),\
	--- A value → `(ok, reason?)`.\
	validate: (value: any) -> (boolean, string?),\
	--- A partial input → completion strings.\
	autocomplete: (prefix: string) -> { string },\
}\
\
--- A type definition you register. Only `name` and `transform` are required;\
--- the rest have sensible defaults.\
export type Def = {\
	name: string,\
	transform: ((raw: string) -> (any, string?))?,\
	validate: ((value: any) -> (boolean, string?))?,\
	autocomplete: ((prefix: string) -> { string })?,\
	--- Marks a whole-number type so ranges over it enumerate integers.\
	integer: boolean?,\
}\
\
local ENUM_CAP = 60 -- never suggest more than this many range values\
\
local registry: { [string]: Def } = {}\
\
local function identity(raw: string): (any, string?)\
	return raw, nil\
end\
local function alwaysValid(): (boolean, string?)\
	return true\
end\
local function noCompletions(): { string }\
	return {}\
end\
\
--- Registers (or replaces) a type definition.\
function Types.register(def: Def)\
	registry[def.name] = def\
end\
\
--- Returns the raw definition registered under `name`, if any.\
function Types.get(name: string): Def?\
	return registry[name]\
end\
\
-- ── built-in primitives ─────────────────────────────────────────────────────\
\
Types.register({\
	name = \"String\",\
	transform = identity,\
	validate = function(v)\
		return type(v) == \"string\", if type(v) == \"string\" then nil else \"expected a string\"\
	end,\
})\
\
Types.register({\
	name = \"Number\",\
	transform = function(raw)\
		local n = tonumber(raw)\
		if n == nil then\
			return nil, `'{raw}' is not a number`\
		end\
		return n\
	end,\
	validate = function(v)\
		return type(v) == \"number\", if type(v) == \"number\" then nil else \"expected a number\"\
	end,\
})\
\
Types.register({\
	name = \"Integer\",\
	integer = true,\
	transform = function(raw)\
		local n = tonumber(raw)\
		if n == nil then\
			return nil, `'{raw}' is not a number`\
		end\
		if n % 1 ~= 0 then\
			return nil, `'{raw}' is not a whole number`\
		end\
		return n\
	end,\
	validate = function(v)\
		if type(v) ~= \"number\" then\
			return false, \"expected a number\"\
		end\
		return v % 1 == 0, if v % 1 == 0 then nil else \"expected a whole number\"\
	end,\
})\
\
Types.register({\
	name = \"Boolean\",\
	transform = function(raw)\
		local low = string.lower(raw)\
		if low == \"true\" or low == \"yes\" or low == \"y\" or low == \"1\" then\
			return true\
		elseif low == \"false\" or low == \"no\" or low == \"n\" or low == \"0\" then\
			return false\
		end\
		return nil, `'{raw}' is not true/false`\
	end,\
	validate = function(v)\
		return type(v) == \"boolean\", if type(v) == \"boolean\" then nil else \"expected a boolean\"\
	end,\
	autocomplete = function(prefix)\
		local out = {}\
		for _, word in { \"true\", \"false\" } do\
			if string.sub(word, 1, #prefix) == prefix then\
				table.insert(out, word)\
			end\
		end\
		return out\
	end,\
})\
\
-- ── compilation ─────────────────────────────────────────────────────────────\
\
local compileNode: (node: any) -> Type\
\
local function unknownType(name: string): Type\
	return {\
		name = name,\
		transform = function()\
			return nil, `unknown type '{name}'`\
		end,\
		validate = function()\
			return false, `unknown type '{name}'`\
		end,\
		autocomplete = noCompletions,\
	}\
end\
\
local function compileName(node: any): Type\
	local def = registry[node.name]\
	if not def then\
		return unknownType(node.name)\
	end\
	return {\
		name = def.name,\
		transform = def.transform or identity,\
		validate = def.validate or alwaysValid,\
		autocomplete = def.autocomplete or noCompletions,\
	}\
end\
\
-- is the innermost atom a whole-number type? (so a range enumerates integers)\
local function innerIsInteger(node: any): boolean\
	if node.kind == \"Name\" then\
		local def = registry[node.name]\
		return def ~= nil and def.integer == true\
	elseif node.kind == \"Range\" then\
		return innerIsInteger(node.inner)\
	elseif node.kind == \"Intersection\" then\
		for _, part in node.parts do\
			if innerIsInteger(part) then\
				return true\
			end\
		end\
	end\
	return false\
end\
\
local function compileRange(node: any): Type\
	local inner = compileNode(node.inner)\
	local min, minInc, max, maxInc = node.min, node.minInc, node.max, node.maxInc\
	local isInt = innerIsInteger(node.inner)\
\
	local function boundsText(): string\
		local lo = if min ~= nil then `{min}{if minInc then \" ≤\" else \" <\"}` else \"\"\
		local hi = if max ~= nil then `{if maxInc then \"≤ \" else \"< \"}{max}` else \"\"\
		return `{lo} {inner.name} {hi}`\
	end\
\
	local function inRange(v: number): (boolean, string?)\
		if min ~= nil then\
			if minInc and v < min then\
				return false, `must be ≥ {min}`\
			elseif not minInc and v <= min then\
				return false, `must be > {min}`\
			end\
		end\
		if max ~= nil then\
			if maxInc and v > max then\
				return false, `must be ≤ {max}`\
			elseif not maxInc and v >= max then\
				return false, `must be < {max}`\
			end\
		end\
		return true\
	end\
\
	return {\
		name = boundsText(),\
		transform = inner.transform,\
		validate = function(v)\
			local ok, why = inner.validate(v)\
			if not ok then\
				return false, why\
			end\
			if type(v) ~= \"number\" then\
				return false, \"expected a number\"\
			end\
			return inRange(v)\
		end,\
		autocomplete = function(prefix)\
			-- enumerate only a fully-bounded integer range; otherwise nothing useful\
			if not isInt or min == nil or max == nil then\
				return {}\
			end\
			local lo = if minInc then math.ceil(min) else math.floor(min) + 1\
			local hi = if maxInc then math.floor(max) else math.ceil(max) - 1\
			local out = {}\
			for value = lo, hi do\
				if #out >= ENUM_CAP then\
					break\
				end\
				local text = tostring(value)\
				if string.sub(text, 1, #prefix) == prefix then\
					table.insert(out, text)\
				end\
			end\
			return out\
		end,\
	}\
end\
\
local function dedupe(list: { string }): { string }\
	local seen, out = {}, {}\
	for _, item in list do\
		if not seen[item] then\
			seen[item] = true\
			table.insert(out, item)\
		end\
	end\
	return out\
end\
\
local function compileUnion(node: any): Type\
	local options = {}\
	local names = {}\
	for _, opt in node.options do\
		local t = compileNode(opt)\
		table.insert(options, t)\
		table.insert(names, t.name)\
	end\
	return {\
		name = table.concat(names, \" | \"),\
		transform = function(raw)\
			local firstErr\
			for _, opt in options do\
				local value, err = opt.transform(raw)\
				if err == nil then\
					local ok = opt.validate(value)\
					if ok then\
						return value\
					end\
				end\
				firstErr = firstErr or err\
			end\
			return nil, firstErr or `'{raw}' matched no option`\
		end,\
		validate = function(v)\
			for _, opt in options do\
				if opt.validate(v) then\
					return true\
				end\
			end\
			return false, `matched none of {table.concat(names, \" | \")}`\
		end,\
		autocomplete = function(prefix)\
			local out = {}\
			for _, opt in options do\
				for _, s in opt.autocomplete(prefix) do\
					table.insert(out, s)\
				end\
			end\
			return dedupe(out)\
		end,\
	}\
end\
\
local function compileIntersection(node: any): Type\
	local parts = {}\
	local names = {}\
	for _, p in node.parts do\
		local t = compileNode(p)\
		table.insert(parts, t)\
		table.insert(names, t.name)\
	end\
	return {\
		name = table.concat(names, \" & \"),\
		transform = parts[1].transform, -- the first part reads the value; the rest constrain it\
		validate = function(v)\
			for _, part in parts do\
				local ok, why = part.validate(v)\
				if not ok then\
					return false, why\
				end\
			end\
			return true\
		end,\
		autocomplete = function(prefix)\
			-- the first part's completions, kept only if they satisfy the rest\
			local out = {}\
			for _, s in parts[1].autocomplete(prefix) do\
				local value, err = parts[1].transform(s)\
				local keep = err == nil\
				if keep then\
					for i = 2, #parts do\
						if not parts[i].validate(value) then\
							keep = false\
							break\
						end\
					end\
				end\
				if keep then\
					table.insert(out, s)\
				end\
			end\
			return out\
		end,\
	}\
end\
\
function compileNode(node: any): Type\
	if node == nil then\
		return unknownType(\"?\")\
	elseif node.kind == \"Name\" then\
		return compileName(node)\
	elseif node.kind == \"Range\" then\
		return compileRange(node)\
	elseif node.kind == \"Union\" then\
		return compileUnion(node)\
	elseif node.kind == \"Intersection\" then\
		return compileIntersection(node)\
	end\
	return unknownType(node.kind or \"?\")\
end\
\
--- Compiles a type-expression string into a resolved [[Type]]. On a parse error\
--- the returned type rejects everything, and the messages are in `.parseErrors`.\
function Types.compile(source: string): Type & { parseErrors: { string } }\
	local parsed = Expr.parse(source)\
	if parsed.ast == nil or #parsed.errors > 0 then\
		local bad: any = {\
			name = source,\
			optional = parsed.optional,\
			parseErrors = parsed.errors,\
			transform = function()\
				return nil, `invalid type '{source}'`\
			end,\
			validate = function()\
				return false, `invalid type '{source}'`\
			end,\
			autocomplete = noCompletions,\
		}\
		return bad\
	end\
	local resolved: any = compileNode(parsed.ast)\
	resolved.optional = parsed.optional\
	resolved.parseErrors = parsed.errors\
	return resolved\
end\
\
return Types\
"},
{"Repl/_Main/Types/Expr","ModuleScript","--- Parses a **type expression** — the text after the colon in an `Args` entry —\
--- into a small AST the [[Types]] engine compiles. This is what makes\
--- `Player | Character`, `Number & Int32`, and `2 < Number < 30` real.\
---\
--- Grammar (low → high precedence):\
--- `Union(|) → Intersection(&) → Range(bounded atom) → Atom(Name | \"(\" expr \")\")`.\
--- A trailing `?` on the whole expression marks the argument optional.\
--- @section Types\
--- @client\
\
local Expr = {}\
\
export type Node = any -- { kind: \"Union\"|\"Intersection\"|\"Range\"|\"Name\", ... }\
\
export type ParseResult = {\
	ast: Node?,\
	optional: boolean,\
	errors: { string },\
}\
\
type Tok = { t: string, v: any }\
\
local COMPARE: { [string]: boolean } = { [\"<\"] = true, [\">\"] = true, [\"<=\"] = true, [\">=\"] = true }\
\
local function tokenize(source: string): { Tok }\
	local toks: { Tok } = {}\
	local i, n = 1, #source\
	while i <= n do\
		local c = string.sub(source, i, i)\
		if string.match(c, \"%s\") then\
			i += 1\
		elseif c == \"|\" or c == \"&\" or c == \"(\" or c == \")\" or c == \"?\" then\
			table.insert(toks, { t = c })\
			i += 1\
		elseif c == \"<\" or c == \">\" then\
			if string.sub(source, i + 1, i + 1) == \"=\" then\
				table.insert(toks, { t = c .. \"=\" })\
				i += 2\
			else\
				table.insert(toks, { t = c })\
				i += 1\
			end\
		elseif string.match(c, \"%d\") or (c == \"-\" and string.match(string.sub(source, i + 1, i + 1), \"%d\")) then\
			local j = if c == \"-\" then i + 1 else i\
			while j <= n and string.match(string.sub(source, j, j), \"[%d%.]\") do\
				j += 1\
			end\
			table.insert(toks, { t = \"num\", v = tonumber(string.sub(source, i, j - 1)) })\
			i = j\
		elseif string.match(c, \"[%a_]\") then\
			local j = i\
			while j <= n and string.match(string.sub(source, j, j), \"[%w_]\") do\
				j += 1\
			end\
			table.insert(toks, { t = \"name\", v = string.sub(source, i, j - 1) })\
			i = j\
		else\
			i += 1 -- lenient: skip anything unrecognized\
		end\
	end\
	table.insert(toks, { t = \"eof\" })\
	return toks\
end\
\
--- Parses a type-expression string. Never throws; returns the AST (or nil),\
--- whether the argument is optional (trailing `?`), and any errors.\
function Expr.parse(source: string): ParseResult\
	local toks = tokenize(source)\
	local pos = 1\
	local errors: { string } = {}\
\
	local function cur(): Tok\
		return toks[pos]\
	end\
	local function at(t: string): boolean\
		return toks[pos].t == t\
	end\
	local function advance(): Tok\
		local tok = toks[pos]\
		if tok.t ~= \"eof\" then\
			pos += 1\
		end\
		return tok\
	end\
	local function err(message: string)\
		table.insert(errors, message)\
	end\
\
	local parseUnion, parseIntersection, parseConstrained, parseAtom\
\
	function parseAtom(): Node?\
		if at(\"(\") then\
			advance()\
			local inner = parseUnion()\
			if at(\")\") then\
				advance()\
			else\
				err(\"expected ')'\")\
			end\
			return inner\
		elseif at(\"name\") then\
			local nameTok = advance()\
			return { kind = \"Name\", name = nameTok.v }\
		end\
		err(`unexpected '{cur().t}' in a type`)\
		if not at(\"eof\") then\
			advance()\
		end\
		return nil\
	end\
\
	-- a bounded atom: [num op] atom [op num]  (a range/conditional), else the atom\
	function parseConstrained(): Node?\
		local leadNum, leadOp\
		if at(\"num\") then\
			leadNum = advance().v\
			if COMPARE[cur().t] then\
				leadOp = advance().t\
			else\
				err(\"expected a comparison after the bound\")\
			end\
		end\
		local atom = parseAtom()\
		local trailOp, trailNum\
		if COMPARE[cur().t] then\
			trailOp = advance().t\
			if at(\"num\") then\
				trailNum = advance().v\
			else\
				err(\"expected a number after the comparison\")\
			end\
		end\
		if leadNum == nil and trailNum == nil then\
			return atom\
		end\
		local node: any = { kind = \"Range\", inner = atom }\
		-- lead:  leadNum <op> atom\
		if leadNum ~= nil and leadOp then\
			if leadOp == \"<\" then\
				node.min, node.minInc = leadNum, false\
			elseif leadOp == \"<=\" then\
				node.min, node.minInc = leadNum, true\
			elseif leadOp == \">\" then\
				node.max, node.maxInc = leadNum, false\
			elseif leadOp == \">=\" then\
				node.max, node.maxInc = leadNum, true\
			end\
		end\
		-- trail:  atom <op> trailNum\
		if trailNum ~= nil and trailOp then\
			if trailOp == \"<\" then\
				node.max, node.maxInc = trailNum, false\
			elseif trailOp == \"<=\" then\
				node.max, node.maxInc = trailNum, true\
			elseif trailOp == \">\" then\
				node.min, node.minInc = trailNum, false\
			elseif trailOp == \">=\" then\
				node.min, node.minInc = trailNum, true\
			end\
		end\
		return node\
	end\
\
	function parseIntersection(): Node?\
		local left = parseConstrained()\
		if not at(\"&\") then\
			return left\
		end\
		local parts = { left }\
		while at(\"&\") do\
			advance()\
			table.insert(parts, parseConstrained())\
		end\
		return { kind = \"Intersection\", parts = parts }\
	end\
\
	function parseUnion(): Node?\
		local left = parseIntersection()\
		if not at(\"|\") then\
			return left\
		end\
		local options = { left }\
		while at(\"|\") do\
			advance()\
			table.insert(options, parseIntersection())\
		end\
		return { kind = \"Union\", options = options }\
	end\
\
	local ast = parseUnion()\
	local optional = false\
	if at(\"?\") then\
		advance()\
		optional = true\
	end\
	if not at(\"eof\") then\
		err(`trailing '{cur().t}' in a type`)\
	end\
	return { ast = ast, optional = optional, errors = errors }\
end\
\
return Expr\
"},
{"Repl/_Packages","Folder",nil},
{"Repl/_Patterns","ModuleScript","--- The pattern types Repl passes around: [[Result]] (a command outcome with an\
--- exit code) and [[Option]] (a maybe-value). `Stream` (incremental output) lands\
--- here alongside them once the Output model is in.\
--- @section Patterns\
--- @client\
\
local Patterns = {}\
\
Patterns.Result = require(script.Result)\
Patterns.Option = require(script.Option)\
\
return Patterns\
"},
{"Repl/_Patterns/Option","ModuleScript","--- An **Option** — `some(value)` or `none()` — for the many places Repl has\
--- \"maybe a value\": a resolved return, an optional argument, a looked-up command.\
--- Keeps `nil`-juggling out of the call sites. Pairs with [[Result]].\
--- @section Patterns\
--- @client\
\
local Option = {}\
Option.__index = Option\
\
export type Option = typeof(setmetatable({} :: { present: boolean, value: any }, Option))\
\
--- An option holding `value`.\
function Option.some(value: any): Option\
	return setmetatable({ present = true, value = value }, Option)\
end\
\
--- The empty option.\
function Option.none(): Option\
	return setmetatable({ present = false }, Option)\
end\
\
--- `some(value)` if `value ~= nil`, else `none()`.\
function Option.of(value: any): Option\
	if value == nil then\
		return Option.none()\
	end\
	return Option.some(value)\
end\
\
--- True if `value` is an Option.\
function Option.is(value: any): boolean\
	return type(value) == \"table\" and getmetatable(value) == Option\
end\
\
function Option.isSome(self: Option): boolean\
	return self.present\
end\
\
function Option.isNone(self: Option): boolean\
	return not self.present\
end\
\
--- The value if present; raises otherwise.\
function Option.unwrap(self: Option): any\
	if self.present then\
		return self.value\
	end\
	error(\"unwrap on a none Option\", 2)\
end\
\
--- The value if present, else `default`.\
function Option.unwrapOr(self: Option, default: any): any\
	if self.present then\
		return self.value\
	end\
	return default\
end\
\
--- Maps the value if present; a none passes through.\
function Option.map(self: Option, fn: (any) -> any): Option\
	if self.present then\
		return Option.of(fn(self.value))\
	end\
	return self\
end\
\
--- Chains an Option-returning fn if present; a none short-circuits.\
function Option.andThen(self: Option, fn: (any) -> Option): Option\
	if self.present then\
		return fn(self.value)\
	end\
	return self\
end\
\
--- Branches: `arms.some(value)` or `arms.none()`.\
function Option.match(self: Option, arms: { some: (any) -> any, none: () -> any }): any\
	if self.present then\
		return arms.some(self.value)\
	end\
	return arms.none()\
end\
\
return Option\
"},
{"Repl/_Patterns/Result","ModuleScript","--- A **Result** — the typed outcome a command handler returns. `ok` carries a\
--- value, `err` a message, and `abort` a cancellation; each has an exit `code`\
--- (0 / 1 / 130) so the shell can branch chains (`a && b`, `a || b`) on real\
--- outcomes rather than guessing from a return value. Pairs with [[Option]] and\
--- backs `ctx:ok` / `ctx:err` / `ctx:abort`.\
--- @section Patterns\
--- @client\
\
local Result = {}\
Result.__index = Result\
\
export type Result = typeof(setmetatable(\
	{} :: { ok: boolean, value: any, error: string?, code: number, aborted: boolean? },\
	Result\
))\
\
--- A success carrying `value` (exit code 0).\
function Result.ok(value: any): Result\
	return setmetatable({ ok = true, value = value, code = 0 }, Result)\
end\
\
--- A failure carrying `message` (exit code defaults to 1).\
function Result.err(message: string, code: number?): Result\
	return setmetatable({ ok = false, error = message, code = code or 1 }, Result)\
end\
\
--- A cancellation (exit code 130, mirroring SIGINT) — distinct from an error.\
function Result.abort(reason: string?): Result\
	return setmetatable({ ok = false, error = reason or \"aborted\", code = 130, aborted = true }, Result)\
end\
\
--- True if `value` is a Result.\
function Result.is(value: any): boolean\
	return type(value) == \"table\" and getmetatable(value) == Result\
end\
\
function Result.isOk(self: Result): boolean\
	return self.ok\
end\
\
function Result.isErr(self: Result): boolean\
	return not self.ok\
end\
\
--- The value on ok; raises the error message on err.\
function Result.unwrap(self: Result): any\
	if self.ok then\
		return self.value\
	end\
	error(self.error or \"unwrap on an err Result\", 2)\
end\
\
--- The value on ok, else `default`.\
function Result.unwrapOr(self: Result, default: any): any\
	if self.ok then\
		return self.value\
	end\
	return default\
end\
\
--- Maps the value on ok, passing err/abort through untouched.\
function Result.map(self: Result, fn: (any) -> any): Result\
	if self.ok then\
		return Result.ok(fn(self.value))\
	end\
	return self\
end\
\
--- Chains a Result-returning fn on ok; short-circuits on err/abort.\
function Result.andThen(self: Result, fn: (any) -> Result): Result\
	if self.ok then\
		return fn(self.value)\
	end\
	return self\
end\
\
--- Branches: `arms.ok(value)` or `arms.err(message, code)`.\
function Result.match(self: Result, arms: { ok: (any) -> any, err: (string?, number) -> any }): any\
	if self.ok then\
		return arms.ok(self.value)\
	end\
	return arms.err(self.error, self.code)\
end\
\
return Result\
"},
{"Repl/_Utility","Folder",nil},
{"Repl/_Utility/Fuzzy","ModuleScript","--- The **fuzzy matcher** behind autocomplete. A query matches a candidate when\
--- its characters appear in order (a subsequence); the score rewards matches at\
--- the start, on word boundaries (after `.` `_` `-` `/` space, or a camelCase\
--- hump), and in consecutive runs — so `pk` ranks `players.kill` above a stray\
--- mid-word hit. Returns the matched positions too, for highlighting.\
--- @section Utility\
--- @client\
\
local Fuzzy = {}\
\
export type Match = {\
	value: string,\
	score: number,\
	positions: { number }, -- 1-based indices in `value` that matched, in query order\
}\
\
local SEPARATORS = \"[%._%-/ ]\"\
\
local function isBoundary(candidate: string, pos: number): boolean\
	if pos == 1 then\
		return true\
	end\
	local prev = string.sub(candidate, pos - 1, pos - 1)\
	if string.match(prev, SEPARATORS) then\
		return true\
	end\
	-- camelCase hump: a lowercase char followed by an uppercase one\
	local cur = string.sub(candidate, pos, pos)\
	return string.match(prev, \"%l\") ~= nil and string.match(cur, \"%u\") ~= nil\
end\
\
--- Matches `query` against `candidate`. Returns `(score, positions)` or nil if\
--- the query is not a subsequence. An empty query matches everything at score 0.\
function Fuzzy.match(query: string, candidate: string): (number?, { number }?)\
	if query == \"\" then\
		return 0, {}\
	end\
\
	local q = string.lower(query)\
	local c = string.lower(candidate)\
	local positions: { number } = {}\
	local qi = 1\
	for ci = 1, #c do\
		if qi > #q then\
			break\
		end\
		if string.sub(c, ci, ci) == string.sub(q, qi, qi) then\
			positions[qi] = ci\
			qi += 1\
		end\
	end\
	if qi <= #q then\
		return nil, nil -- not every query char was consumed\
	end\
\
	local score = 0\
	local prev: number? = nil\
	for k, pos in positions do\
		score += 1\
		if prev ~= nil and pos == prev + 1 then\
			score += 5 -- consecutive run\
		end\
		if isBoundary(candidate, pos) then\
			score += 10\
		end\
		if pos == 1 then\
			score += 15 -- matches the very start\
		end\
		if k == 1 then\
			score -= (pos - 1) -- penalize how far in the first match sits\
		end\
		prev = pos\
	end\
	return score, positions\
end\
\
--- Filters and ranks `candidates` against `query`, best first (ties broken\
--- alphabetically). Non-matches are dropped.\
function Fuzzy.filter(query: string, candidates: { string }): { Match }\
	local results: { Match } = {}\
	for _, candidate in candidates do\
		local score, positions = Fuzzy.match(query, candidate)\
		if score ~= nil then\
			table.insert(results, { value = candidate, score = score, positions = positions :: { number } })\
		end\
	end\
	table.sort(results, function(a, b)\
		if a.score ~= b.score then\
			return a.score > b.score\
		end\
		return a.value < b.value\
	end)\
	return results\
end\
\
return Fuzzy\
"},
{"Repl/_Utility/Render","ModuleScript","--- Rendering. The headless [[Output]] model (Segment/Line/Block + a plain-text\
--- flattener) lives here; the Fusion terminal renderer that turns those nodes\
--- into themed, animated instances joins it later (Studio-only).\
--- @section Render\
--- @client\
\
local Render = {}\
\
Render.Output = require(script.Output)\
\
return Render\
"},
{"Repl/_Utility/Render/Output","ModuleScript","--- The **structured output model**. Commands never print strings — they emit\
--- `Segment`s (styled text runs), grouped into `Line`s, optionally grouped into\
--- a `Block` (a table, an ascii art, a status panel). Colors are *semantic\
--- tokens* (`\"success\"`, `\"error\"`, `\"accent\"`, `\"muted\"`…), not `Color3`, so the\
--- same output recolors live when the theme changes and stays fully headless.\
--- `toText` flattens any node to plain text for logs and no-UI fallbacks.\
--- @section Render\
--- @client\
\
local Output = {}\
\
--- A styled run of text. `color` is a semantic token resolved by the theme.\
export type Segment = {\
	text: string,\
	color: string?,\
	bold: boolean?,\
	italic: boolean?,\
	underline: boolean?,\
	icon: string?, -- a Lucide icon name rendered before the text\
}\
\
--- A row of segments. `kind` gives it semantic meaning (and a default color):\
--- \"plain\" | \"success\" | \"error\" | \"warn\" | \"info\" | \"message\".\
export type Line = {\
	class: \"Line\",\
	kind: string,\
	segments: { Segment },\
}\
\
--- A group of lines with a structural `kind`: \"block\" | \"table\" | \"ascii\" | \"status\".\
export type Block = {\
	class: \"Block\",\
	kind: string,\
	lines: { Line },\
}\
\
export type Node = Line | Block\
\
--- Builds a styled segment. `style` may set color/bold/italic/underline/icon.\
function Output.segment(text: string, style: { [string]: any }?): Segment\
	local segment: Segment = { text = text }\
	if style then\
		segment.color = style.color\
		segment.bold = style.bold\
		segment.italic = style.italic\
		segment.underline = style.underline\
		segment.icon = style.icon\
	end\
	return segment\
end\
\
-- coerce a string, a segment, or a list of segments into a segment list\
local function toSegments(content: string | Segment | { Segment }): { Segment }\
	if type(content) == \"string\" then\
		return { Output.segment(content) }\
	elseif (content :: any).text ~= nil then\
		return { content :: Segment } -- a lone segment\
	end\
	return content :: { Segment }\
end\
\
--- Builds a line of the given `kind` from a string, a segment, or segments.\
function Output.line(kind: string, content: string | Segment | { Segment }): Line\
	return { class = \"Line\", kind = kind, segments = toSegments(content) }\
end\
\
-- semantic one-liners: each tags the line kind and colors its text to match\
local function semantic(kind: string, color: string)\
	return function(text: string): Line\
		return { class = \"Line\", kind = kind, segments = { Output.segment(text, { color = color }) } }\
	end\
end\
\
--- A neutral line.\
Output.plain = semantic(\"plain\", \"text\")\
--- A success line (green token).\
Output.success = semantic(\"success\", \"success\")\
--- An error line (red token).\
Output.error = semantic(\"error\", \"error\")\
--- A warning line (yellow token).\
Output.warn = semantic(\"warn\", \"warn\")\
--- An informational line (accent token).\
Output.info = semantic(\"info\", \"accent\")\
--- A muted, secondary line.\
Output.message = semantic(\"message\", \"muted\")\
\
--- Groups lines into a block of the given structural `kind`.\
function Output.block(kind: string, lines: { Line }): Block\
	return { class = \"Block\", kind = kind, lines = lines }\
end\
\
--- Builds a simple text table block from rows of cells (each cell becomes a\
--- muted-separated segment run; columns are padded to align).\
function Output.table(rows: { { string } }): Block\
	-- compute column widths\
	local widths: { number } = {}\
	for _, row in rows do\
		for col, cell in row do\
			widths[col] = math.max(widths[col] or 0, #cell)\
		end\
	end\
	local lines: { Line } = {}\
	for _, row in rows do\
		local segments: { Segment } = {}\
		for col, cell in row do\
			local padded = cell .. string.rep(\" \", (widths[col] or 0) - #cell)\
			table.insert(segments, Output.segment(padded))\
			if col < #row then\
				table.insert(segments, Output.segment(\"  \", { color = \"muted\" }))\
			end\
		end\
		table.insert(lines, { class = \"Line\", kind = \"plain\", segments = segments })\
	end\
	return Output.block(\"table\", lines)\
end\
\
--- Flattens a line or block to plain text (styling dropped), joining a block's\
--- lines with newlines. Icons render as `[name] `.\
function Output.toText(node: Node): string\
	local function lineText(line: Line): string\
		local parts = {}\
		for _, seg in line.segments do\
			if seg.icon then\
				table.insert(parts, `[{seg.icon}] `)\
			end\
			table.insert(parts, seg.text)\
		end\
		return table.concat(parts)\
	end\
\
	if node.class == \"Line\" then\
		return lineText(node :: Line)\
	end\
	local out = {}\
	for _, line in (node :: Block).lines do\
		table.insert(out, lineText(line))\
	end\
	return table.concat(out, \"\\n\")\
end\
\
return Output\
"},
{"Repl/_Utility/Shell","ModuleScript","--- The shell front end: source → tokens → AST. Re-exports the stages\
--- ([[Lexer]], [[Parser]], [[Ast]], [[Token]]) and the two entry points.\
--- @section Shell\
--- @client\
\
local Shell = {}\
\
Shell.Token = require(script.Token)\
Shell.Lexer = require(script.Lexer)\
Shell.Ast = require(script.Ast)\
Shell.Parser = require(script.Parser)\
Shell.ReturnPool = require(script.ReturnPool)\
\
--- Tokenize source into a flat token list + diagnostics.\
Shell.tokenize = Shell.Lexer.tokenize\
--- Tokenize and parse source into an AST + diagnostics.\
Shell.parse = Shell.Parser.parse\
\
return Shell\
"},
{"Repl/_Utility/Shell/Ast","ModuleScript","--- AST node kinds for the Repl shell. The [[Parser]] builds plain tables tagged\
--- with a `kind` from `Ast.Kind`; the [[Evaluator]] dispatches on it.\
--- @section Shell\
--- @client\
\
local Ast = {}\
\
Ast.Kind = {\
	-- structure\
	Program = \"Program\", -- { chains: {Chain} }\
	Chain = \"Chain\", -- { steps: { {op: string?, node} }, directives: {string} }\
	Command = \"Command\", -- { name, nameToken, args: {Arg}, flags: {string}, ambiguous: boolean? }\
	Guarded = \"Guarded\", -- { guard: Guard, block: Program }\
	Guard = \"Guard\", -- { terms: { {op: string?, negate: boolean, expr} } }\
	ValueStmt = \"ValueStmt\", -- { value }  (a bare reference or group used as a statement)\
	Pipeline = \"Pipeline\", -- { stages: {Command} }  (a | b | c: thread each output into the next)\
\
	-- values / args\
	Literal = \"Literal\", -- { valueType: \"string\"|\"number\"|\"boolean\"|\"nil\", value }\
	Reference = \"Reference\", -- { last: boolean, name: string?, index: number?, path: {string} }\
	VarRef = \"VarRef\", -- { name: string, path: {string} }\
	TypeValue = \"TypeValue\", -- { typeName: string }\
	Assignment = \"Assignment\", -- { name: string, value }\
\
	-- expressions\
	Binary = \"Binary\", -- { op: string, left, right }\
	Unary = \"Unary\", -- { op: \"~\"|\"neg\", operand }\
	IsNil = \"IsNil\", -- { operand }  (postfix `!`)\
}\
\
return Ast\
"},
{"Repl/_Utility/Shell/Lexer","ModuleScript","--- The Repl shell lexer: source text → a flat list of neutral [[Token]]s.\
---\
--- Neutral means no FLAG / DIRECTIVE / SLASH_REF / SLASH_DIV tokens: `-`, `--`,\
--- `/`, `//` come out as plain operator tokens and the [[Parser]] assigns meaning\
--- by context and by `spaceBefore` adjacency. The lexer never throws — malformed\
--- input yields diagnostics and the scan continues, which also backs analysis.\
--- @section Shell\
--- @client\
\
local Token = require(script.Parent.Token)\
local Kind = Token.Kind\
\
local Lexer = {}\
\
export type Diagnostic = {\
	message: string,\
	pos: number,\
	line: number,\
	col: number,\
	len: number,\
}\
\
export type LexResult = {\
	tokens: { Token.Token },\
	diagnostics: { Diagnostic },\
}\
\
local function isDigit(b: number?): boolean\
	return b ~= nil and b >= 48 and b <= 57\
end\
\
local function isAlpha(b: number?): boolean\
	-- letters or underscore\
	return b ~= nil and ((b >= 65 and b <= 90) or (b >= 97 and b <= 122) or b == 95)\
end\
\
local function isAlphaNum(b: number?): boolean\
	return isDigit(b) or isAlpha(b)\
end\
\
--- Tokenizes `source`. Always returns tokens (ending in an EOF token) plus any\
--- diagnostics; it never errors.\
function Lexer.tokenize(source: string): LexResult\
	local tokens: { Token.Token } = {}\
	local diagnostics: { Diagnostic } = {}\
\
	local i = 1\
	local n = #source\
	local line = 1\
	local lineStart = 1 -- byte index where the current line begins (for column math)\
	local spaceBefore = false\
\
	local function col(pos: number): number\
		return pos - lineStart + 1\
	end\
\
	local function addDiag(message: string, pos: number, len: number)\
		table.insert(diagnostics, { message = message, pos = pos, line = line, col = col(pos), len = len })\
	end\
\
	local function push(kind: Token.Kind, text: string, value: any, pos: number)\
		table.insert(tokens, {\
			kind = kind,\
			text = text,\
			value = value,\
			pos = pos,\
			line = line,\
			col = col(pos),\
			spaceBefore = spaceBefore,\
		})\
		spaceBefore = false\
	end\
\
	-- does the char at p keep a bareword going. lets us lex things like 1,200,1\
	-- (vectors), a,b,c (player lists) and 1.5,2,3 as one token instead of choking\
	-- on the comma\
	local function continues(p: number, allowDot: boolean): boolean\
		local c = string.byte(source, p)\
		if isAlphaNum(c) then\
			return true\
		end\
		if c == 45 and isAlpha(string.byte(source, p + 1)) then\
			return true -- internal -letter, eg Ignore-Errors\
		end\
		if c == 44 and isAlphaNum(string.byte(source, p + 1)) then\
			return true -- comma separated list\
		end\
		if allowDot and c == 46 and isDigit(string.byte(source, p + 1)) then\
			return true -- decimal inside a coord\
		end\
		return false\
	end\
\
	while i <= n do\
		local b = string.byte(source, i)\
\
		if b == 32 or b == 9 then\
			-- space / tab\
			spaceBefore = true\
			i += 1\
		elseif b == 10 or b == 13 then\
			-- newline: \\n, \\r, or \\r\\n as one\
			local startPos = i\
			push(Kind.Newline, \"\\n\", nil, startPos)\
			i += 1\
			if b == 13 and string.byte(source, i) == 10 then\
				i += 1\
			end\
			line += 1\
			lineStart = i\
		elseif isDigit(b) then\
			-- NUMBER: digits [ . digits ] (unsigned; sign is the parser's job).\
			-- But a digit run directly followed by a letter is a bareword: 1d, 30s, 5m.\
			local startPos = i\
			while isDigit(string.byte(source, i)) do\
				i += 1\
			end\
			-- optional decimal part\
			if string.byte(source, i) == 46 and isDigit(string.byte(source, i + 1)) then\
				i += 1\
				while isDigit(string.byte(source, i)) do\
					i += 1\
				end\
			end\
			-- if a letter or comma list follows its a bareword (1d, 30s, 1,200,1, 1.5,2,3)\
			if continues(i, true) then\
				while continues(i, true) do\
					i += 1\
				end\
				local text = string.sub(source, startPos, i - 1)\
				push(Kind.Ident, text, text, startPos)\
			else\
				local text = string.sub(source, startPos, i - 1)\
				push(Kind.Number, text, tonumber(text), startPos)\
			end\
		elseif isAlpha(b) then\
			-- IDENT / BOOL. Internal '-' is kept only when followed by a letter/_, so\
			-- `Ignore-Errors` is one ident but `x-2` splits into x, -, 2.\
			local startPos = i\
			i += 1\
			while continues(i, false) do\
				i += 1\
			end\
			local text = string.sub(source, startPos, i - 1)\
			if text == \"true\" then\
				push(Kind.Boolean, text, true, startPos)\
			elseif text == \"false\" then\
				push(Kind.Boolean, text, false, startPos)\
			else\
				push(Kind.Ident, text, text, startPos)\
			end\
		elseif b == 34 then\
			-- STRING with the full Luau escape set.\
			local startPos = i\
			i += 1\
			local buf: { string } = {}\
			local terminated = false\
			while i <= n do\
				local c = string.byte(source, i)\
				if c == 34 then\
					i += 1\
					terminated = true\
					break\
				elseif c == 10 or c == 13 then\
					break -- raw newline => unterminated\
				elseif c == 92 then\
					-- escape\
					i += 1\
					local e = string.byte(source, i)\
					if e == nil then\
						break\
					elseif e == 110 then\
						table.insert(buf, \"\\n\")\
						i += 1\
					elseif e == 116 then\
						table.insert(buf, \"\\t\")\
						i += 1\
					elseif e == 114 then\
						table.insert(buf, \"\\r\")\
						i += 1\
					elseif e == 34 then\
						table.insert(buf, '\"')\
						i += 1\
					elseif e == 92 then\
						table.insert(buf, \"\\\\\")\
						i += 1\
					elseif e == 97 then\
						table.insert(buf, \"\\a\")\
						i += 1\
					elseif e == 98 then\
						table.insert(buf, \"\\b\")\
						i += 1\
					elseif e == 102 then\
						table.insert(buf, \"\\f\")\
						i += 1\
					elseif e == 118 then\
						table.insert(buf, \"\\v\")\
						i += 1\
					elseif e == 120 then\
						-- \\xHH\
						local hex = string.sub(source, i + 1, i + 2)\
						local code = #hex == 2 and tonumber(hex, 16) or nil\
						if code then\
							table.insert(buf, string.char(code))\
							i += 3\
						else\
							addDiag(\"invalid \\\\x escape (expected two hex digits)\", i - 1, 2)\
							i += 1\
						end\
					elseif e == 117 then\
						-- \\u{HEX}\
						if string.byte(source, i + 1) == 123 then\
							local close = string.find(source, \"}\", i + 2, true)\
							if close then\
								local hex = string.sub(source, i + 2, close - 1)\
								local code = tonumber(hex, 16)\
								if code then\
									table.insert(buf, utf8.char(code))\
									i = close + 1\
								else\
									addDiag(\"invalid \\\\u{...} escape\", i - 1, close - (i - 1) + 1)\
									i += 1\
								end\
							else\
								addDiag(\"unterminated \\\\u{ escape\", i - 1, 2)\
								i += 1\
							end\
						else\
							addDiag(\"malformed \\\\u escape (expected '{')\", i - 1, 2)\
							i += 1\
						end\
					elseif isDigit(e) then\
						-- \\ddd decimal, 1-3 digits\
						local k = i\
						local ds = {}\
						while #ds < 3 and isDigit(string.byte(source, k)) do\
							table.insert(ds, string.char(string.byte(source, k) :: number))\
							k += 1\
						end\
						local code = tonumber(table.concat(ds))\
						if code and code <= 255 then\
							table.insert(buf, string.char(code))\
							i = k\
						else\
							addDiag(\"decimal escape out of range (0-255)\", i - 1, #ds + 1)\
							i = k\
						end\
					else\
						addDiag(\"unknown escape sequence\", i - 1, 2)\
						table.insert(buf, string.char(e))\
						i += 1\
					end\
				else\
					table.insert(buf, string.char(c))\
					i += 1\
				end\
			end\
			local text = string.sub(source, startPos, i - 1)\
			if not terminated then\
				addDiag(\"unterminated string literal\", startPos, #text)\
			end\
			push(Kind.String, text, table.concat(buf), startPos)\
		elseif b == 91 and (isDigit(string.byte(source, i + 1)) or string.byte(source, i + 1) == 45) then\
			-- [1,2,3] wraps a coord/value list into one token, brackets stripped. a [\
			-- before a letter is left as a normal bracket (eg @TYPE[Player])\
			local startPos = i\
			local close = string.find(source, \"]\", i + 1, true)\
			if close then\
				local inner = string.gsub(string.sub(source, i + 1, close - 1), \"%s\", \"\")\
				push(Kind.Ident, inner, inner, startPos)\
				i = close + 1\
			else\
				push(Kind.LBracket, \"[\", nil, startPos)\
				i += 1\
			end\
		else\
			-- operators / punctuation, longest match first\
			local startPos = i\
			local b2 = string.byte(source, i + 1)\
			if b == 47 and b2 == 47 then\
				push(Kind.SlashSlash, \"//\", nil, startPos)\
				i += 2\
			elseif b == 38 and b2 == 38 then\
				push(Kind.AmpAmp, \"&&\", nil, startPos)\
				i += 2\
			elseif b == 124 and b2 == 124 then\
				push(Kind.PipePipe, \"||\", nil, startPos)\
				i += 2\
			elseif b == 61 and b2 == 61 then\
				push(Kind.EqEq, \"==\", nil, startPos)\
				i += 2\
			elseif b == 33 and b2 == 61 then\
				push(Kind.BangEq, \"!=\", nil, startPos)\
				i += 2\
			elseif b == 62 and b2 == 61 then\
				push(Kind.Gte, \">=\", nil, startPos)\
				i += 2\
			elseif b == 60 and b2 == 61 then\
				push(Kind.Lte, \"<=\", nil, startPos)\
				i += 2\
			elseif b == 45 and b2 == 45 then\
				push(Kind.MinusMinus, \"--\", nil, startPos)\
				i += 2\
			else\
				local kind: Token.Kind? = nil\
				if b == 47 then\
					kind = Kind.Slash\
				elseif b == 46 then\
					kind = Kind.Dot\
				elseif b == 35 then\
					kind = Kind.Hash\
				elseif b == 64 then\
					kind = Kind.At\
				elseif b == 61 then\
					kind = Kind.Assign\
				elseif b == 33 then\
					kind = Kind.Bang\
				elseif b == 126 then\
					kind = Kind.Tilde\
				elseif b == 38 then\
					kind = Kind.Amp\
				elseif b == 124 then\
					kind = Kind.Pipe\
				elseif b == 59 then\
					kind = Kind.Semicolon\
				elseif b == 62 then\
					kind = Kind.Gt\
				elseif b == 60 then\
					kind = Kind.Lt\
				elseif b == 43 then\
					kind = Kind.Plus\
				elseif b == 45 then\
					kind = Kind.Minus\
				elseif b == 42 then\
					kind = Kind.Star\
				elseif b == 37 then\
					kind = Kind.Percent\
				elseif b == 40 then\
					kind = Kind.LParen\
				elseif b == 41 then\
					kind = Kind.RParen\
				elseif b == 123 then\
					kind = Kind.LBrace\
				elseif b == 125 then\
					kind = Kind.RBrace\
				elseif b == 91 then\
					kind = Kind.LBracket\
				elseif b == 93 then\
					kind = Kind.RBracket\
				end\
\
				if kind then\
					push(kind, string.char(b), nil, startPos)\
					i += 1\
				else\
					addDiag(string.format(\"unexpected character %q\", string.char(b)), startPos, 1)\
					i += 1\
				end\
			end\
		end\
	end\
\
	push(Kind.EOF, \"\", nil, i)\
	return { tokens = tokens, diagnostics = diagnostics }\
end\
\
return Lexer\
"},
{"Repl/_Utility/Shell/Parser","ModuleScript","--- Recursive-descent parser for the Repl shell: [[Token]]s → [[Ast]] + diagnostics.\
---\
--- The parser is where **context** lives: the same `/` token becomes a reference\
--- in value position and division in operator position; `&&` is chain control\
--- between statements and boolean inside an expression. Nothing here throws —\
--- errors are collected as diagnostics with best-effort recovery, so this also\
--- powers analysis/highlighting.\
--- @section Shell\
--- @client\
\
local Lexer = require(script.Parent.Lexer)\
local Token = require(script.Parent.Token)\
local Ast = require(script.Parent.Ast)\
\
local K = Token.Kind\
local N = Ast.Kind\
\
local Parser = {}\
\
export type ParseResult = {\
	ast: any,\
	diagnostics: { Lexer.Diagnostic },\
}\
\
-- tokens that can begin an argument / expression operand (used for juxtaposition)\
local ARG_START: { [string]: boolean } = {\
	[K.Ident] = true,\
	[K.Number] = true,\
	[K.String] = true,\
	[K.Boolean] = true,\
	[K.At] = true,\
	[K.Slash] = true,\
	[K.SlashSlash] = true,\
	[K.LParen] = true,\
}\
\
-- binary operators that, after an operand, mean \"this is an expression\"\
local BINOP: { [string]: boolean } = {\
	[K.Plus] = true,\
	[K.Star] = true,\
	[K.Percent] = true,\
	[K.EqEq] = true,\
	[K.BangEq] = true,\
	[K.Gt] = true,\
	[K.Lt] = true,\
	[K.Gte] = true,\
	[K.Lte] = true,\
	[K.AmpAmp] = true,\
	[K.PipePipe] = true,\
	-- Minus and Slash are handled specially (adjacency decides flag/ref vs operator)\
}\
\
local COMPARE: { [string]: string } = {\
	[K.EqEq] = \"==\",\
	[K.BangEq] = \"!=\",\
	[K.Gt] = \">\",\
	[K.Lt] = \"<\",\
	[K.Gte] = \">=\",\
	[K.Lte] = \"<=\",\
}\
\
--- Parses a token stream into an [[Ast]], collecting diagnostics (never throws).\
function Parser.parseTokens(tokens: { Token.Token }, diagnostics: { Lexer.Diagnostic }): ParseResult\
	local pos = 1\
	diagnostics = diagnostics or {}\
\
	local function cur(): Token.Token\
		return tokens[pos]\
	end\
	local function kind(): string\
		return tokens[pos].kind\
	end\
	local function at(k: string): boolean\
		return tokens[pos].kind == k\
	end\
	local function peek(off: number): Token.Token?\
		return tokens[pos + off]\
	end\
	local function advance(): Token.Token\
		local t = tokens[pos]\
		if t.kind ~= K.EOF then\
			pos += 1\
		end\
		return t\
	end\
	local function diag(message: string, tok: Token.Token?)\
		tok = tok or cur()\
		table.insert(diagnostics, {\
			message = message,\
			pos = tok.pos,\
			line = tok.line,\
			col = tok.col,\
			len = math.max(#tok.text, 1),\
		})\
	end\
	local function expect(k: string, what: string): Token.Token?\
		if at(k) then\
			return advance()\
		end\
		diag(`expected {what}`)\
		return nil\
	end\
	local function skipNewlines()\
		-- a ';' separates statements exactly like a newline does\
		while at(K.Newline) or at(K.Semicolon) do\
			advance()\
		end\
	end\
\
	-- forward decls\
	local parseProgram, parseChain, parseStatement, parseCommand, parseArgument\
	local parseGroup, parseGroupBody, parseCommandOrExpr\
	local parseExpr, parseAtValue, parseReference, parsePath\
	local tryParseGuarded, parseGuard, parseGuardTerm, parseBlock\
\
	function parsePath(): { string }\
		local path = {}\
		while at(K.Dot) do\
			advance()\
			local id = expect(K.Ident, \"property name\")\
			if id then\
				table.insert(path, id.value)\
			else\
				break\
			end\
		end\
		return path\
	end\
\
	-- @x , @x.prop , @TYPE[name]\
	function parseAtValue(): any\
		advance() -- '@'\
		if not at(K.Ident) then\
			diag(\"expected a name after '@'\")\
			return { kind = N.VarRef, name = \"\", path = {} }\
		end\
		local nameTok = advance()\
		if nameTok.value == \"TYPE\" and at(K.LBracket) then\
			advance() -- '['\
			local typeTok = expect(K.Ident, \"type name\")\
			expect(K.RBracket, \"']'\")\
			return { kind = N.TypeValue, typeName = typeTok and typeTok.value or \"\" }\
		end\
		return { kind = N.VarRef, name = nameTok.value, path = parsePath() }\
	end\
\
	-- // , /Name , with optional #index and .path\
	function parseReference(): any\
		local last = false\
		local name: string? = nil\
		if at(K.SlashSlash) then\
			advance()\
			last = true\
		else\
			advance() -- '/'\
			local id = expect(K.Ident, \"reference name\")\
			name = id and id.value or \"\"\
		end\
		local index: number? = nil\
		if at(K.Hash) then\
			advance()\
			local num = expect(K.Number, \"reference index\")\
			index = num and num.value or nil\
		end\
		return { kind = N.Reference, last = last, name = name, index = index, path = parsePath() }\
	end\
\
	-- ---- expression grammar (precedence climbing) ----\
\
	local function parsePrimary(): any\
		local k = kind()\
		if k == K.Number then\
			local t = advance()\
			return { kind = N.Literal, valueType = \"number\", value = t.value, token = t }\
		elseif k == K.String then\
			local t = advance()\
			return { kind = N.Literal, valueType = \"string\", value = t.value, token = t }\
		elseif k == K.Boolean then\
			local t = advance()\
			return { kind = N.Literal, valueType = \"boolean\", value = t.value, token = t }\
		elseif k == K.Ident then\
			local t = advance() -- bare word in an expression is a literal string\
			return { kind = N.Literal, valueType = \"string\", value = t.value, token = t }\
		elseif k == K.At then\
			return parseAtValue()\
		elseif k == K.Slash or k == K.SlashSlash then\
			return parseReference()\
		elseif k == K.LParen then\
			return parseGroup()\
		else\
			diag(\"expected an expression\")\
			if not at(K.EOF) then\
				advance()\
			end\
			return { kind = N.Literal, valueType = \"nil\", value = nil }\
		end\
	end\
\
	local function parsePostfix(): any\
		local p = parsePrimary()\
		-- postfix nil-tests: `x!` = is-nil, `x~!` = not-nil (here `~` prefixes the `!`).\
		while true do\
			if at(K.Bang) then\
				advance()\
				p = { kind = N.IsNil, operand = p }\
			elseif at(K.Tilde) then\
				local n = peek(1)\
				if n and n.kind == K.Bang then\
					advance() -- '~'\
					advance() -- '!'\
					p = { kind = N.Unary, op = \"~\", operand = { kind = N.IsNil, operand = p } }\
				else\
					break\
				end\
			else\
				break\
			end\
		end\
		return p\
	end\
\
	local function parseUnary(): any\
		if at(K.Tilde) then\
			advance()\
			return { kind = N.Unary, op = \"~\", operand = parseUnary() }\
		elseif at(K.Minus) then\
			advance()\
			return { kind = N.Unary, op = \"neg\", operand = parseUnary() }\
		end\
		return parsePostfix()\
	end\
\
	local function parseMul(): any\
		local left = parseUnary()\
		while at(K.Star) or at(K.Slash) or at(K.Percent) do\
			local op = at(K.Star) and \"*\" or at(K.Slash) and \"/\" or \"%\"\
			advance()\
			left = { kind = N.Binary, op = op, left = left, right = parseUnary() }\
		end\
		return left\
	end\
\
	local function parseAdd(): any\
		local left = parseMul()\
		while at(K.Plus) or at(K.Minus) do\
			local op = at(K.Plus) and \"+\" or \"-\"\
			advance()\
			left = { kind = N.Binary, op = op, left = left, right = parseMul() }\
		end\
		return left\
	end\
\
	local function parseCmp(): any\
		local left = parseAdd()\
		local op = COMPARE[kind()]\
		if op then\
			advance()\
			return { kind = N.Binary, op = op, left = left, right = parseAdd() }\
		end\
		return left\
	end\
\
	local function parseAnd(): any\
		local left = parseCmp()\
		while at(K.AmpAmp) do\
			advance()\
			left = { kind = N.Binary, op = \"&&\", left = left, right = parseCmp() }\
		end\
		return left\
	end\
\
	local function parseOr(): any\
		local left = parseAnd()\
		while at(K.PipePipe) do\
			advance()\
			left = { kind = N.Binary, op = \"||\", left = left, right = parseAnd() }\
		end\
		return left\
	end\
\
	function parseExpr(): any\
		return parseOr()\
	end\
\
	-- ---- group resolution: command-sub vs expression vs assignment ----\
\
	-- returns true (command sub), false (expression), or \"lone\" (ambiguous bare word)\
	local function looksLikeCommandSub(): (boolean | string)\
		if not at(K.Ident) then\
			return false\
		end\
		local n = peek(1)\
		if not n then\
			return false\
		end\
		local nk = n.kind\
		if nk == K.RParen then\
			return \"lone\"\
		end\
		if BINOP[nk] then\
			return false\
		end\
		if nk == K.Minus then\
			-- flag (`word -s`) or negative-number arg (`word -5`) => command; spaced minus => expr\
			local n2 = peek(2)\
			if n2 and not n2.spaceBefore and (n2.kind == K.Ident or n2.kind == K.Number) then\
				return true\
			end\
			return false\
		end\
		if nk == K.Slash then\
			-- `word /Player` (ref arg) => command; `word / 2` (division) => expr\
			local n2 = peek(2)\
			if n2 and not n2.spaceBefore and n2.kind == K.Ident then\
				return true\
			end\
			return false\
		end\
		if ARG_START[nk] then\
			return true\
		end\
		return false\
	end\
\
	function parseCommandOrExpr(): any\
		local verdict = looksLikeCommandSub()\
		if verdict == true then\
			return parseCommand()\
		elseif verdict == \"lone\" then\
			local word = advance()\
			return {\
				kind = N.Command,\
				name = word.value,\
				nameToken = word,\
				args = {},\
				flags = {},\
				ambiguous = true, -- eval: registered command -> run; else literal string\
			}\
		end\
		return parseExpr()\
	end\
\
	function parseGroupBody(): any\
		if at(K.Ident) then\
			local n = peek(1)\
			if n and n.kind == K.Assign then\
				local nameTok = advance()\
				advance() -- '='\
				return { kind = N.Assignment, name = nameTok.value, value = parseCommandOrExpr() }\
			end\
		end\
		return parseCommandOrExpr()\
	end\
\
	function parseGroup(): any\
		expect(K.LParen, \"'('\")\
		local body = parseGroupBody()\
		expect(K.RParen, \"')'\")\
		return body\
	end\
\
	-- ---- commands ----\
\
	function parseArgument(): any?\
		local k = kind()\
		if k == K.Number then\
			local t = advance()\
			return { kind = N.Literal, valueType = \"number\", value = t.value, token = t }\
		elseif k == K.String then\
			local t = advance()\
			return { kind = N.Literal, valueType = \"string\", value = t.value, token = t }\
		elseif k == K.Boolean then\
			local t = advance()\
			return { kind = N.Literal, valueType = \"boolean\", value = t.value, token = t }\
		elseif k == K.Ident then\
			local t = advance()\
			return { kind = N.Literal, valueType = \"string\", value = t.value, token = t }\
		elseif k == K.At then\
			return parseAtValue()\
		elseif k == K.Slash or k == K.SlashSlash then\
			return parseReference()\
		elseif k == K.LParen then\
			return parseGroup()\
		end\
		return nil\
	end\
\
	function parseCommand(): any\
		local nameTok = advance() -- Ident (caller guarantees)\
		local args = {}\
		local flags = {}\
		local modifiers: { [string]: any } = {} -- valued long options: --name=value\
		while true do\
			local k = kind()\
			if\
				k == K.Newline\
				or k == K.EOF\
				or k == K.RParen\
				or k == K.RBrace\
				or k == K.LBrace\
				or k == K.AmpAmp\
				or k == K.PipePipe\
				or k == K.Amp\
			then\
				break\
			elseif k == K.MinusMinus then\
				-- \"--name=value\" is a command modifier; a bare \"--name\" is left for the chain\
				-- directive parser (so --Ignore-Errors / --Dry-Run still work unchanged).\
				local nameNx = peek(1)\
				local eqNx = peek(2)\
				if\
					nameNx and nameNx.kind == K.Ident and not nameNx.spaceBefore\
					and eqNx and eqNx.kind == K.Assign and not eqNx.spaceBefore\
				then\
					advance() -- '--'\
					advance() -- name\
					advance() -- '='\
					local val = parseArgument()\
					if val == nil then\
						diag(`expected a value after '--{nameNx.value}='`)\
						break\
					end\
					modifiers[nameNx.value] = val\
				else\
					break\
				end\
			elseif k == K.Minus then\
				local nx = peek(1)\
				if nx and not nx.spaceBefore and nx.kind == K.Ident then\
					advance() -- '-'\
					-- raw flag chunk; stacking/name resolution happens with the Attributes\
					table.insert(flags, advance().value)\
				elseif nx and not nx.spaceBefore and nx.kind == K.Number then\
					advance() -- '-'\
					local num = advance()\
					table.insert(args, { kind = N.Literal, valueType = \"number\", value = -num.value, token = num })\
				else\
					diag(\"unexpected '-'\")\
					break\
				end\
			else\
				local arg = parseArgument()\
				if arg == nil then\
					break\
				end\
				table.insert(args, arg)\
			end\
		end\
		return { kind = N.Command, name = nameTok.value, nameToken = nameTok, args = args, flags = flags, modifiers = modifiers }\
	end\
\
	-- ---- guards & blocks ----\
\
	function parseGuardTerm(): any?\
		local negate = false\
		if at(K.Tilde) then\
			advance()\
			negate = true\
		end\
		if not at(K.LParen) then\
			return nil\
		end\
		advance() -- '('\
		-- a guard term is a group body: a bare expression `(@x == 4)`, an assignment\
		-- `(x = 2)` (binds, truthy on a non-nil/false value), or a command sub `(isAdmin me)`.\
		-- the evaluator treats all three the same: evaluate, then test truthiness.\
		local body = parseGroupBody()\
		if not at(K.RParen) then\
			return nil\
		end\
		advance() -- ')'\
		return { negate = negate, expr = body }\
	end\
\
	function parseGuard(): any?\
		local first = parseGuardTerm()\
		if not first then\
			return nil\
		end\
		local terms = { first }\
		while at(K.AmpAmp) or at(K.PipePipe) do\
			local op = at(K.AmpAmp) and \"&&\" or \"||\"\
			advance()\
			local term = parseGuardTerm()\
			if not term then\
				return nil\
			end\
			term.op = op\
			table.insert(terms, term)\
		end\
		return { kind = N.Guard, terms = terms }\
	end\
\
	function parseBlock(): any\
		expect(K.LBrace, \"'{'\")\
		local prog = parseProgram(K.RBrace)\
		expect(K.RBrace, \"'}'\")\
		return prog\
	end\
\
	function tryParseGuarded(): any?\
		local savePos = pos\
		local saveDiag = #diagnostics\
		local guard = parseGuard()\
		if guard and at(K.LBrace) then\
			return { kind = N.Guarded, guard = guard, block = parseBlock() }\
		end\
		-- backtrack: it wasn't a guard\
		pos = savePos\
		while #diagnostics > saveDiag do\
			table.remove(diagnostics)\
		end\
		return nil\
	end\
\
	-- ---- statements / chains / program ----\
\
	function parseStatement(): any?\
		if at(K.Tilde) or at(K.LParen) then\
			local guarded = tryParseGuarded()\
			if guarded then\
				return guarded\
			end\
			if at(K.LParen) then\
				return { kind = N.ValueStmt, value = parseGroup() }\
			end\
			diag(\"expected '(' to begin a guard\")\
			advance()\
			return nil\
		elseif at(K.Slash) or at(K.SlashSlash) then\
			return { kind = N.ValueStmt, value = parseReference() }\
		elseif at(K.Ident) then\
			-- a command, possibly the head of a pipeline `a | b | c`\
			local first = parseCommand()\
			if not at(K.Pipe) then\
				return first\
			end\
			local stages = { first }\
			while at(K.Pipe) do\
				advance()\
				if at(K.Ident) then\
					table.insert(stages, parseCommand())\
				else\
					diag(\"expected a command after '|'\")\
					break\
				end\
			end\
			return { kind = N.Pipeline, stages = stages }\
		end\
		local t = cur()\
		diag(`unexpected {t.text ~= \"\" and t.text or t.kind}`)\
		if not at(K.EOF) then\
			advance()\
		end\
		return nil\
	end\
\
	function parseChain(): any\
		local steps = { { op = nil, node = parseStatement() } }\
		while at(K.AmpAmp) or at(K.PipePipe) or at(K.Amp) do\
			local op = at(K.AmpAmp) and \"&&\" or at(K.PipePipe) and \"||\" or \"&\"\
			advance()\
			table.insert(steps, { op = op, node = parseStatement() })\
		end\
		local directives = {}\
		while at(K.MinusMinus) do\
			advance()\
			local id = expect(K.Ident, \"directive name after '--'\")\
			if id then\
				table.insert(directives, id.value)\
			end\
		end\
		return { kind = N.Chain, steps = steps, directives = directives }\
	end\
\
	function parseProgram(stopKind: string?): any\
		local chains = {}\
		skipNewlines()\
		while not at(K.EOF) and not (stopKind ~= nil and at(stopKind)) do\
			local before = pos\
			local chain = parseChain()\
			if chain then\
				table.insert(chains, chain)\
			end\
			if at(K.Newline) or at(K.Semicolon) then\
				skipNewlines()\
			elseif pos == before then\
				-- no progress: force advance so we never loop forever\
				if not at(K.EOF) then\
					diag(`unexpected {cur().kind}`)\
					advance()\
				else\
					break\
				end\
			end\
		end\
		return { kind = N.Program, chains = chains }\
	end\
\
	local ast = parseProgram(nil)\
	return { ast = ast, diagnostics = diagnostics }\
end\
\
--- Tokenizes and parses `source` in one call.\
function Parser.parse(source: string): ParseResult\
	local lexed = Lexer.tokenize(source)\
	return Parser.parseTokens(lexed.tokens, lexed.diagnostics)\
end\
\
return Parser\
"},
{"Repl/_Utility/Shell/ReturnPool","ModuleScript","--- The return pool. Commands push typed/labelled return records; `/` references\
--- read them back. There is no positional stack — you reference returns by *what\
--- they are* (`//` last, `/Player` by type, `/target` by label, `#n` for the\
--- nth-most-recent, `.path` to drill in). Failed links contribute nothing, so\
--- the pool only holds real results.\
--- @section Shell\
--- @client\
\
local ReturnPool = {}\
ReturnPool.__index = ReturnPool\
\
export type Record = {\
	value: any,\
	type: string?, -- the declared/inferred type, e.g. \"Player\"\
	label: string?, -- the Returns-schema name, e.g. \"target\"\
	fromCommand: string?,\
}\
\
export type Reference = {\
	last: boolean, -- `//`\
	name: string?, -- `/Name`\
	index: number?, -- `#n` (1 = most recent)\
	path: { string }, -- `.a.b`\
}\
\
--- Creates an empty pool.\
function ReturnPool.new()\
	return setmetatable({ records = {} :: { Record } }, ReturnPool)\
end\
\
--- Empties the pool (once per top-level line).\
function ReturnPool:clear()\
	table.clear(self.records)\
end\
\
--- Appends a successful return. A nil value is still a valid result and recorded.\
function ReturnPool:push(value: any, valueType: string?, label: string?, fromCommand: string?)\
	table.insert(self.records, { value = value, type = valueType, label = label, fromCommand = fromCommand })\
end\
\
--- The most recent record, or nil.\
function ReturnPool:last(): Record?\
	return self.records[#self.records]\
end\
\
-- nth-most-recent record (1 = newest) satisfying pred\
local function nthMatch(records: { Record }, n: number, pred: (Record) -> boolean): Record?\
	local seen = 0\
	for i = #records, 1, -1 do\
		local r = records[i]\
		if pred(r) then\
			seen += 1\
			if seen == n then\
				return r\
			end\
		end\
	end\
	return nil\
end\
\
local function describe(ref: Reference): string\
	local head = ref.last and \"//\" or (\"/\" .. tostring(ref.name))\
	if ref.index then\
		head ..= \"#\" .. tostring(ref.index)\
	end\
	return head\
end\
\
--- Resolves a reference to its record (a label takes precedence over a type on\
--- a name clash).\
function ReturnPool:resolveRecord(ref: Reference): Record?\
	local n = ref.index or 1\
	if ref.last then\
		return nthMatch(self.records, n, function()\
			return true\
		end)\
	elseif ref.name ~= nil then\
		local name = ref.name\
		local hasLabel = nthMatch(self.records, 1, function(r)\
			return r.label == name\
		end) ~= nil\
		if hasLabel then\
			return nthMatch(self.records, n, function(r)\
				return r.label == name\
			end)\
		end\
		return nthMatch(self.records, n, function(r)\
			return r.type == name\
		end)\
	end\
	return nil\
end\
\
--- Resolves a reference to a value, applying any `.path`. Returns `(value, nil)`\
--- on success or `(nil, errorMessage)` on a missing return or a bad access.\
function ReturnPool:resolve(ref: Reference): (any, string?)\
	local record = self:resolveRecord(ref)\
	if not record then\
		return nil, `no return matching {describe(ref)}`\
	end\
	local value = record.value\
	for _, key in ref.path do\
		if value == nil then\
			return nil, `cannot read '{key}' of nil ({describe(ref)})`\
		end\
		local ok, got = pcall(function()\
			return (value :: any)[key]\
		end)\
		if not ok then\
			return nil, `cannot index '{key}' on {describe(ref)}`\
		end\
		value = got\
	end\
	return value, nil\
end\
\
return ReturnPool\
"},
{"Repl/_Utility/Shell/Token","ModuleScript","--- Token kinds and the `Token` shape for the Repl shell lexer.\
---\
--- The lexer is deliberately **neutral**: it never decides whether a token means\
--- \"reference\" vs \"division\" or \"flag\" vs \"minus\". It emits the smallest tokens\
--- plus `spaceBefore` adjacency, and the [[Parser]] assigns meaning by context\
--- and token position.\
--- @section Shell\
--- @client\
\
local Token = {}\
\
Token.Kind = {\
	Newline = \"Newline\",\
	Semicolon = \"Semicolon\", -- ; (statement separator, same role as a newline)\
\
	-- literals / words\
	Number = \"Number\", -- 5, 3.14\
	String = \"String\", -- \"...\"\
	Boolean = \"Boolean\", -- true, false\
	Ident = \"Ident\", -- names: commands, args, vars, labels, types\
\
	-- references / sigils\
	Slash = \"Slash\", -- /\
	SlashSlash = \"SlashSlash\", -- //\
	Dot = \"Dot\", -- .\
	Hash = \"Hash\", -- #\
	At = \"At\", -- @\
\
	-- assignment / logic primitives\
	Assign = \"Assign\", -- =\
	Bang = \"Bang\", -- !\
	Tilde = \"Tilde\", -- ~\
\
	-- chain / boolean\
	AmpAmp = \"AmpAmp\", -- &&\
	PipePipe = \"PipePipe\", -- ||\
	Amp = \"Amp\", -- &\
	Pipe = \"Pipe\", -- | (pipeline: feed one command's output into the next)\
\
	-- comparison\
	EqEq = \"EqEq\", -- ==\
	BangEq = \"BangEq\", -- !=\
	Gte = \"Gte\", -- >=\
	Lte = \"Lte\", -- <=\
	Gt = \"Gt\", -- >\
	Lt = \"Lt\", -- <\
\
	-- arithmetic / dashes\
	Plus = \"Plus\", -- +\
	Minus = \"Minus\", -- -\
	MinusMinus = \"MinusMinus\", -- --\
	Star = \"Star\", -- *\
	Percent = \"Percent\", -- %\
\
	-- brackets\
	LParen = \"LParen\", -- (\
	RParen = \"RParen\", -- )\
	LBrace = \"LBrace\", -- {\
	RBrace = \"RBrace\", -- }\
	LBracket = \"LBracket\", -- [\
	RBracket = \"RBracket\", -- ]\
\
	EOF = \"EOF\",\
}\
\
export type Kind = string\
\
--- One lexed token. `value` is the cooked value for literals; `spaceBefore`\
--- records whether whitespace separated this token from the previous one (so the\
--- parser can tell `-s` the flag from `- s` the operator).\
export type Token = {\
	kind: Kind,\
	text: string, -- raw source text matched\
	value: any, -- cooked value: number | string | boolean | nil\
	pos: number, -- 1-based byte offset of the first char\
	line: number,\
	col: number, -- 1-based byte column within the line\
	spaceBefore: boolean, -- was this token separated from the previous by whitespace?\
}\
\
return Token\
"},
{"Repl/_Utility/Theme","ModuleScript","--- The **Theme**. Every color in Repl — terminal output, the bar chrome, every\
--- [[Output]] Segment, every Repl.UI widget — is named by a *semantic token*\
--- (`accent`, `success`, `error`, `bg`, `prompt`…), never a literal color. A\
--- theme maps those tokens to a palette; `Set` swaps the palette and notifies\
--- listeners, which is what makes the whole surface recolor live. Ships\
--- tokyonight, gruvbox, catppuccin, and nord.\
---\
--- The palette values are hex strings so the engine stays headless; `Color3`\
--- resolves them at the Roblox boundary (`Theme:Color3(token)`).\
--- @section Theme\
--- @client\
\
local Theme = {}\
\
--- The full token set every palette must define.\
export type Token =\
	\"bg\" | \"bgAlt\" | \"text\" | \"muted\" | \"accent\" | \"success\" | \"error\" | \"warn\" | \"info\" | \"border\" | \"selection\" | \"cursor\" | \"prompt\"\
\
export type Palette = { [string]: string }\
\
local TOKENS: { string } = {\
	\"bg\", \"bgAlt\", \"text\", \"muted\", \"accent\",\
	\"success\", \"error\", \"warn\", \"info\",\
	\"border\", \"selection\", \"cursor\", \"prompt\",\
}\
\
local PALETTES: { [string]: Palette } = {\
	tokyonight = {\
		bg = \"#24283b\", bgAlt = \"#1f2335\", text = \"#c0caf5\", muted = \"#565f89\", accent = \"#7aa2f7\",\
		success = \"#9ece6a\", error = \"#f7768e\", warn = \"#e0af68\", info = \"#7dcfff\",\
		border = \"#414868\", selection = \"#364a82\", cursor = \"#c0caf5\", prompt = \"#bb9af7\",\
	},\
	gruvbox = {\
		bg = \"#282828\", bgAlt = \"#1d2021\", text = \"#ebdbb2\", muted = \"#928374\", accent = \"#83a598\",\
		success = \"#b8bb26\", error = \"#fb4934\", warn = \"#fabd2f\", info = \"#8ec07c\",\
		border = \"#3c3836\", selection = \"#504945\", cursor = \"#ebdbb2\", prompt = \"#d3869b\",\
	},\
	catppuccin = {\
		bg = \"#1e1e2e\", bgAlt = \"#181825\", text = \"#cdd6f4\", muted = \"#6c7086\", accent = \"#89b4fa\",\
		success = \"#a6e3a1\", error = \"#f38ba8\", warn = \"#f9e2af\", info = \"#94e2d5\",\
		border = \"#313244\", selection = \"#45475a\", cursor = \"#f5e0dc\", prompt = \"#cba6f7\",\
	},\
	nord = {\
		bg = \"#2e3440\", bgAlt = \"#272c36\", text = \"#eceff4\", muted = \"#4c566a\", accent = \"#88c0d0\",\
		success = \"#a3be8c\", error = \"#bf616a\", warn = \"#ebcb8b\", info = \"#81a1c1\",\
		border = \"#3b4252\", selection = \"#434c5e\", cursor = \"#d8dee9\", prompt = \"#b48ead\",\
	},\
}\
\
local SCHEMES: { string } = { \"tokyonight\", \"gruvbox\", \"catppuccin\", \"nord\" }\
\
Theme.current = \"tokyonight\"\
Theme.tokens = TOKENS\
local listeners: { (name: string) -> () } = {}\
\
--- The list of built-in scheme names.\
function Theme.list(): { string }\
	return table.clone(SCHEMES)\
end\
\
--- Whether a scheme is registered.\
function Theme.has(name: string): boolean\
	return PALETTES[name] ~= nil\
end\
\
--- Registers (or overrides) a scheme. It must define every [[Token]].\
function Theme.register(name: string, palette: Palette)\
	for _, token in TOKENS do\
		if palette[token] == nil then\
			error(`theme '{name}' is missing the '{token}' token`, 2)\
		end\
	end\
	if not PALETTES[name] then\
		table.insert(SCHEMES, name)\
	end\
	PALETTES[name] = table.clone(palette)\
end\
\
--- Switches the active scheme and notifies every listener (the live recolor).\
function Theme:Set(name: string)\
	if not PALETTES[name] then\
		error(`unknown theme '{name}' (have: {table.concat(SCHEMES, \", \")})`, 2)\
	end\
	self.current = name\
	for _, fn in listeners do\
		fn(name)\
	end\
end\
\
--- The hex string for a token in the active scheme (falls back to `text`).\
function Theme:Get(token: string): string\
	local palette = PALETTES[self.current]\
	return palette[token] or palette.text\
end\
\
--- The active palette (a copy).\
function Theme:Palette(): Palette\
	return table.clone(PALETTES[self.current])\
end\
\
--- Subscribes to scheme changes; returns an unsubscribe function.\
function Theme:OnChange(fn: (name: string) -> ()): () -> ()\
	table.insert(listeners, fn)\
	return function()\
		local index = table.find(listeners, fn)\
		if index then\
			table.remove(listeners, index)\
		end\
	end\
end\
\
--- Resolves a token to a `Color3` (Roblox only).\
function Theme:Color3(token: string): Color3\
	return Color3.fromHex(self:Get(token))\
end\
\
return Theme\
"},
