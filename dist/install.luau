	local mRoot = m ^ (1/3)\
	local sRoot = s ^ (1/3)\
\
	return Vector3.new(\
		lRoot * 0.2104542553 + mRoot * 0.7936177850 - sRoot * 0.0040720468,\
		lRoot * 1.9779984951 - mRoot * 2.4285922050 + sRoot * 0.4505937099,\
		lRoot * 0.0259040371 + mRoot * 0.7827717662 - sRoot * 0.8086757660\
	)\
