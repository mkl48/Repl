return Render\
"},
{"Repl/_Utility/Render/Icons","ModuleScript","--- The **icon map**: icon name → Roblox asset id. The PNGs live in\
--- `assets/icons/png` (white, so they tint to the theme via `ImageColor3`) — upload\
--- them and fill in the ids below, or set them at runtime with `Icons.set` /\
--- `Repl.Icons.set(name, \"rbxassetid://…\")`. Until an id is set, the [[Terminal]]\
--- falls back to rendering `[name]` as text, so nothing breaks.\
---\
--- Semantic aliases (`success`, `error`, `warn`, `prompt`, …) map onto the base\
--- glyphs so `ctx:icon(\"success\", …)` and Output line kinds resolve without\
--- knowing the underlying icon.\
--- @section Render\
--- @client\
\
local Icons = {}\
\
--- name → `rbxassetid://…`. Fill these after uploading `assets/icons/png/*`.\
Icons.assets = {\
	[\"check\"] = nil :: string?,\
	[\"x\"] = nil :: string?,\
	[\"info\"] = nil :: string?,\
	[\"warn\"] = nil :: string?,\
	[\"chevron-right\"] = nil :: string?,\
	[\"chevron-down\"] = nil :: string?,\
	[\"terminal\"] = nil :: string?,\
	[\"circle-check\"] = nil :: string?,\
	[\"circle-x\"] = nil :: string?,\
	[\"circle-alert\"] = nil :: string?,\
	[\"arrow-right\"] = nil :: string?,\
	[\"search\"] = nil :: string?,\
	[\"folder\"] = nil :: string?,\
	[\"zap\"] = nil :: string?,\
	[\"clock\"] = nil :: string?,\
	[\"user\"] = nil :: string?,\
	[\"hash\"] = nil :: string?,\
	[\"play\"] = nil :: string?,\
	[\"settings\"] = nil :: string?,\
	[\"list\"] = nil :: string?,\
} :: { [string]: string? }\
\
--- semantic name → base glyph\
Icons.aliases = {\
	success = \"check\",\
	error = \"x\",\
	err = \"x\",\
	warn = \"warn\",\
	warning = \"warn\",\
	info = \"info\",\
	prompt = \"chevron-right\",\
	ok = \"circle-check\",\
	fail = \"circle-x\",\
	alert = \"circle-alert\",\
	help = \"info\",\
	commands = \"list\",\
	time = \"clock\",\
}\
\
--- Resolves an icon name (or alias) to its asset id, or nil if unset.\
function Icons.resolve(name: string): string?\
	local base = Icons.aliases[name] or name\
	return Icons.assets[base]\
end\
\
--- Sets an asset id for a base icon name (accepts a number or a full string).\
function Icons.set(name: string, assetId: string | number)\
	if type(assetId) == \"number\" then\
		assetId = `rbxassetid://{assetId}`\
	end\
	Icons.assets[name] = assetId\
end\
\
--- Bulk-set from a `{ [name] = id }` table.\
function Icons.setMany(map: { [string]: string | number })\
	for name, assetId in map do\
		Icons.set(name, assetId)\
	end\
end\
\
return Icons\
"},
{"Repl/_Utility/Render/Output","ModuleScript","--- The **structured output model**. Commands never print strings — they emit\
--- `Segment`s (styled text runs), grouped into `Line`s, optionally grouped into\
--- a `Block` (a table, an ascii art, a status panel). Colors are *semantic\
--- tokens* (`\"success\"`, `\"error\"`, `\"accent\"`, `\"muted\"`…), not `Color3`, so the\
--- same output recolors live when the theme changes and stays fully headless.\
--- `toText` flattens any node to plain text for logs and no-UI fallbacks.\
--- @section Render\
--- @client\
\
local Output = {}\
\
--- A styled run of text. `color` is a semantic token resolved by the theme.\
export type Segment = {\
	text: string,\
	color: string?,\
	bold: boolean?,\
	italic: boolean?,\
	underline: boolean?,\
	icon: string?, -- a Lucide icon name rendered before the text\
}\
\
--- A row of segments. `kind` gives it semantic meaning (and a default color):\
--- \"plain\" | \"success\" | \"error\" | \"warn\" | \"info\" | \"message\".\
export type Line = {\
	class: \"Line\",\
	kind: string,\
	segments: { Segment },\
}\
\
--- A group of lines with a structural `kind`: \"block\" | \"table\" | \"ascii\" | \"status\".\
export type Block = {\
	class: \"Block\",\
	kind: string,\
	lines: { Line },\
}\
\
export type Node = Line | Block\
\
--- Builds a styled segment. `style` may set color/bold/italic/underline/icon.\
function Output.segment(text: string, style: { [string]: any }?): Segment\
	local segment: Segment = { text = text }\
	if style then\
		segment.color = style.color\
		segment.bold = style.bold\
		segment.italic = style.italic\
		segment.underline = style.underline\
		segment.icon = style.icon\
	end\
	return segment\
end\
\
-- coerce a string, a segment, or a list of segments into a segment list\
local function toSegments(content: string | Segment | { Segment }): { Segment }\
	if type(content) == \"string\" then\
		return { Output.segment(content) }\
	elseif (content :: any).text ~= nil then\
		return { content :: Segment } -- a lone segment\
	end\
	return content :: { Segment }\
end\
\
--- Builds a line of the given `kind` from a string, a segment, or segments.\
function Output.line(kind: string, content: string | Segment | { Segment }): Line\
	return { class = \"Line\", kind = kind, segments = toSegments(content) }\
end\
\
-- semantic one-liners: each tags the line kind and colors its text to match\
local function semantic(kind: string, color: string)\
	return function(text: string): Line\
		return { class = \"Line\", kind = kind, segments = { Output.segment(text, { color = color }) } }\
	end\
end\
\
--- A neutral line.\
Output.plain = semantic(\"plain\", \"text\")\
--- A success line (green token).\
Output.success = semantic(\"success\", \"success\")\
--- An error line (red token).\
Output.error = semantic(\"error\", \"error\")\
--- A warning line (yellow token).\
Output.warn = semantic(\"warn\", \"warn\")\
--- An informational line (accent token).\
Output.info = semantic(\"info\", \"accent\")\
--- A muted, secondary line.\
Output.message = semantic(\"message\", \"muted\")\
\
--- Groups lines into a block of the given structural `kind`.\
function Output.block(kind: string, lines: { Line }): Block\
	return { class = \"Block\", kind = kind, lines = lines }\
end\
\
--- Builds a simple text table block from rows of cells (each cell becomes a\
--- muted-separated segment run; columns are padded to align).\
function Output.table(rows: { { string } }): Block\
	-- compute column widths\
	local widths: { number } = {}\
	for _, row in rows do\
		for col, cell in row do\
			widths[col] = math.max(widths[col] or 0, #cell)\
		end\
	end\
	local lines: { Line } = {}\
	for _, row in rows do\
		local segments: { Segment } = {}\
		for col, cell in row do\
			local padded = cell .. string.rep(\" \", (widths[col] or 0) - #cell)\
			table.insert(segments, Output.segment(padded))\
			if col < #row then\
				table.insert(segments, Output.segment(\"  \", { color = \"muted\" }))\
			end\
		end\
		table.insert(lines, { class = \"Line\", kind = \"plain\", segments = segments })\
	end\
	return Output.block(\"table\", lines)\
end\
\
--- Flattens a line or block to plain text (styling dropped), joining a block's\
--- lines with newlines. Icons render as `[name] `.\
function Output.toText(node: Node): string\
	local function lineText(line: Line): string\
		local parts = {}\
		for _, seg in line.segments do\
			if seg.icon then\
				table.insert(parts, `[{seg.icon}] `)\
			end\
			table.insert(parts, seg.text)\
		end\
		return table.concat(parts)\
	end\
\
	if node.class == \"Line\" then\
		return lineText(node :: Line)\
	end\
	local out = {}\
	for _, line in (node :: Block).lines do\
		table.insert(out, lineText(line))\
	end\
	return table.concat(out, \"\\n\")\
end\
\
return Output\
"},
{"Repl/_Utility/Render/Terminal","ModuleScript","--- The **terminal renderer**: maps the headless [[Output]] tree (Segment/Line/\
--- Block) to Fusion instances. A Line becomes one RichText label whose text is a\
--- `Computed` — so bold/italic/underline render inline and every segment's\
--- [[Theme]] color re-evaluates the moment the scheme changes. A Block becomes a\
--- vertically-stacked frame of lines. Studio-only (pulls Fusion).\
---\
--- Icons (Lucide) are not yet drawn as images — a segment's `icon` is rendered as\
--- a `[name]` text marker until the Lucide asset map lands.\
--- @section Render\
--- @client\
\
local Fusion = require(script.Parent.Parent.Parent._Packages.Fusion)\
local Theme = require(script.Parent.Parent.Theme)\
local Theming = require(script.Parent.Theming)\
local Output = require(script.Parent.Output)\
local Icons = require(script.Parent.Icons)\
\
local Children = Fusion.Children\
\
local Terminal = {}\
\
local FONT = Enum.Font.Code -- a monospace terminal face\
local TEXT_SIZE = 16\
local LINE_PADDING = 2\
\
-- RichText needs &, <, > escaped in literal text\
local function escape(text: string): string\
	text = string.gsub(text, \"&\", \"&amp;\")\
	text = string.gsub(text, \"<\", \"&lt;\")\
	text = string.gsub(text, \">\", \"&gt;\")\
	return text\
end\
\
-- one segment → a RichText run, colored by the *current* theme. An icon that\
-- resolves to an uploaded image is drawn separately (see Terminal.line); an\
-- unmapped icon falls back to a `[name]` text marker so nothing is lost.\
local function richSegment(segment: Output.Segment): string\
	local body = escape(segment.text)\
	if segment.icon and not Icons.resolve(segment.icon) then\
		body = `[{escape(segment.icon)}] ` .. body\
	end\
	if segment.bold then\
		body = `<b>{body}</b>`\
	end\
	if segment.italic then\
		body = `<i>{body}</i>`\
	end\
	if segment.underline then\
		body = `<u>{body}</u>`\
	end\
	local color = Theme:Get(segment.color or \"text\")\
	return `<font color=\"{color}\">{body}</font>`\
end\
\
-- the RichText label carrying a line's text\
local function textLabel(scope: any, line: Output.Line): TextLabel\
	return scope:New \"TextLabel\" {\
		Name = \"Text\",\
		BackgroundTransparency = 1,\
		AutomaticSize = Enum.AutomaticSize.Y,\
		Size = UDim2.new(1, 0, 0, 0),\
		Font = FONT,\
		TextSize = TEXT_SIZE,\
		TextXAlignment = Enum.TextXAlignment.Left,\
		TextYAlignment = Enum.TextYAlignment.Top,\
		TextWrapped = true,\
		RichText = true,\
		TextColor3 = Theming.color(scope, \"text\"), -- fallback for any unfonted run\
		Text = scope:Computed(function(use)\
			use(Theming.scheme) -- rebuild (and recolor) when the scheme changes\
			local parts = {}\
			for _, segment in line.segments do\
				table.insert(parts, richSegment(segment))\
			end\
			return table.concat(parts)\
		end),\
	}\
end\
\
--- Renders a single [[Output]] Line. If its first segment carries an icon that\
--- resolves to an uploaded image, the line becomes an `[icon][text]` row (the\
--- icon tinted to that segment's color); otherwise it's a lone RichText label.\
function Terminal.line(scope: any, line: Output.Line): Instance\
	local lead = line.segments[1]\
	local leadAsset = lead and lead.icon and Icons.resolve(lead.icon)\
	if not leadAsset then\
		return textLabel(scope, line)\
	end\
	return scope:New \"Frame\" {\
		Name = `Line_{line.kind}`,\
		BackgroundTransparency = 1,\
		AutomaticSize = Enum.AutomaticSize.Y,\
		Size = UDim2.new(1, 0, 0, 0),\
		[Children] = {\
			scope:New \"UIListLayout\" {\
				FillDirection = Enum.FillDirection.Horizontal,\
				SortOrder = Enum.SortOrder.LayoutOrder,\
				VerticalAlignment = Enum.VerticalAlignment.Top,\
				Padding = UDim.new(0, 6),\
			},\
			scope:New \"ImageLabel\" {\
				Name = \"Icon\",\
				BackgroundTransparency = 1,\
				Image = leadAsset,\
				ImageColor3 = Theming.color(scope, lead.color or \"text\"),\
				ScaleType = Enum.ScaleType.Fit,\
				Size = UDim2.fromOffset(TEXT_SIZE, TEXT_SIZE),\
				LayoutOrder = 1,\
			},\
			(function()\
				local label = textLabel(scope, line)\
				label.LayoutOrder = 2\
				-- fill the width the icon leaves\
				scope:New \"UIFlexItem\" { FlexMode = Enum.UIFlexMode.Fill, Parent = label }\
				return label\
			end)(),\
		},\
	}\
end\
\
--- Renders an [[Output]] Block as a vertically-stacked frame of lines.\
function Terminal.block(scope: any, block: Output.Block): Frame\
	local lines = {}\
	for _, line in block.lines do\
		table.insert(lines, Terminal.line(scope, line))\
	end\
	return scope:New \"Frame\" {\
		Name = `Block_{block.kind}`,\
		BackgroundTransparency = 1,\
		AutomaticSize = Enum.AutomaticSize.Y,\
		Size = UDim2.new(1, 0, 0, 0),\
		[Children] = {\
			scope:New \"UIListLayout\" {\
				FillDirection = Enum.FillDirection.Vertical,\
				SortOrder = Enum.SortOrder.LayoutOrder,\
				Padding = UDim.new(0, LINE_PADDING),\
			},\
			lines,\
		},\
	}\
end\
\
--- Renders any [[Output]] node (Line or Block) to an instance.\
function Terminal.render(scope: any, node: Output.Node): Instance\
	if node.class == \"Block\" then\
		return Terminal.block(scope, node :: Output.Block)\
	end\
	return Terminal.line(scope, node :: Output.Line)\
end\
\
return Terminal\
"},
{"Repl/_Utility/Render/Theming","ModuleScript","--- The **theme → Fusion bridge**. [[Theme]] is a plain, headless module; this\
--- wraps its active scheme in a Fusion `Value` and hands out `Computed` colors,\
--- so any instance property bound with `Theming.color(scope, token)` recolors the\
--- instant `Theme:Set` runs. Studio-only (pulls Fusion).\
--- @section Render\
--- @client\
\
local Fusion = require(script.Parent.Parent.Parent._Packages.Fusion)\
local Theme = require(script.Parent.Parent.Theme)\
\
local scoped = Fusion.scoped\
\
local Theming = {}\
\
-- one persistent, app-global scope holding the active-scheme state; it lives for\
-- the session, so it is intentionally never cleaned up\
local root = scoped(Fusion)\
local scheme = root:Value(Theme.current)\
\
-- mirror every Theme:Set into the Fusion graph\
Theme:OnChange(function(name)\
	scheme:set(name)\
end)\
\
--- The Fusion `Value` holding the active scheme name (track it in a Computed to\
--- react to theme changes).\
Theming.scheme = scheme\
\
--- A `Computed` `Color3` for `token` in the active scheme — rebinds live.\
function Theming.color(scope: any, token: string): any\
	return scope:Computed(function(use)\
		use(scheme) -- re-evaluate whenever the scheme changes\
		return Color3.fromHex(Theme:Get(token))\
	end)\
end\
\
--- The current hex value for `token` (non-reactive, for one-off reads).\
function Theming.hex(token: string): string\
	return Theme:Get(token)\
end\
\
return Theming\
"},
{"Repl/_Utility/Shell","ModuleScript","--- The shell front end: source → tokens → AST. Re-exports the stages\
--- ([[Lexer]], [[Parser]], [[Ast]], [[Token]]) and the two entry points.\
--- @section Shell\
--- @client\
\
local Shell = {}\
\
Shell.Token = require(script.Token)\
Shell.Lexer = require(script.Lexer)\
Shell.Ast = require(script.Ast)\
Shell.Parser = require(script.Parser)\
Shell.ReturnPool = require(script.ReturnPool)\
\
--- Tokenize source into a flat token list + diagnostics.\
Shell.tokenize = Shell.Lexer.tokenize\
--- Tokenize and parse source into an AST + diagnostics.\
Shell.parse = Shell.Parser.parse\
\
return Shell\
"},
{"Repl/_Utility/Shell/Ast","ModuleScript","--- AST node kinds for the Repl shell. The [[Parser]] builds plain tables tagged\
--- with a `kind` from `Ast.Kind`; the [[Evaluator]] dispatches on it.\
--- @section Shell\
--- @client\
\
local Ast = {}\
\
Ast.Kind = {\
	-- structure\
	Program = \"Program\", -- { chains: {Chain} }\
	Chain = \"Chain\", -- { steps: { {op: string?, node} }, directives: {string} }\
	Command = \"Command\", -- { name, nameToken, args: {Arg}, flags: {string}, ambiguous: boolean? }\
	Guarded = \"Guarded\", -- { guard: Guard, block: Program }\
	Guard = \"Guard\", -- { terms: { {op: string?, negate: boolean, expr} } }\
	ValueStmt = \"ValueStmt\", -- { value }  (a bare reference or group used as a statement)\
	Pipeline = \"Pipeline\", -- { stages: {Command} }  (a | b | c: thread each output into the next)\
\
	-- values / args\
	Literal = \"Literal\", -- { valueType: \"string\"|\"number\"|\"boolean\"|\"nil\", value }\
	Reference = \"Reference\", -- { last: boolean, name: string?, index: number?, path: {string} }\
	VarRef = \"VarRef\", -- { name: string, path: {string} }\
	TypeValue = \"TypeValue\", -- { typeName: string }\
	Assignment = \"Assignment\", -- { name: string, value }\
\
	-- expressions\
	Binary = \"Binary\", -- { op: string, left, right }\
	Unary = \"Unary\", -- { op: \"~\"|\"neg\", operand }\
	IsNil = \"IsNil\", -- { operand }  (postfix `!`)\
}\
\
return Ast\
"},
{"Repl/_Utility/Shell/Lexer","ModuleScript","--- The Repl shell lexer: source text → a flat list of neutral [[Token]]s.\
---\
--- Neutral means no FLAG / DIRECTIVE / SLASH_REF / SLASH_DIV tokens: `-`, `--`,\
--- `/`, `//` come out as plain operator tokens and the [[Parser]] assigns meaning\
--- by context and by `spaceBefore` adjacency. The lexer never throws — malformed\
--- input yields diagnostics and the scan continues, which also backs analysis.\
--- @section Shell\
--- @client\
\
local Token = require(script.Parent.Token)\
local Kind = Token.Kind\
\
local Lexer = {}\
\
export type Diagnostic = {\
	message: string,\
	pos: number,\
	line: number,\
	col: number,\
	len: number,\
}\
\
export type LexResult = {\
	tokens: { Token.Token },\
	diagnostics: { Diagnostic },\
}\
\
local function isDigit(b: number?): boolean\
	return b ~= nil and b >= 48 and b <= 57\
end\
\
local function isAlpha(b: number?): boolean\
	-- letters or underscore\
	return b ~= nil and ((b >= 65 and b <= 90) or (b >= 97 and b <= 122) or b == 95)\
end\
\
local function isAlphaNum(b: number?): boolean\
	return isDigit(b) or isAlpha(b)\
end\
\
--- Tokenizes `source`. Always returns tokens (ending in an EOF token) plus any\
--- diagnostics; it never errors.\
function Lexer.tokenize(source: string): LexResult\
	local tokens: { Token.Token } = {}\
	local diagnostics: { Diagnostic } = {}\
\
	local i = 1\
	local n = #source\
	local line = 1\
	local lineStart = 1 -- byte index where the current line begins (for column math)\
	local spaceBefore = false\
\
	local function col(pos: number): number\
		return pos - lineStart + 1\
	end\
\
	local function addDiag(message: string, pos: number, len: number)\
		table.insert(diagnostics, { message = message, pos = pos, line = line, col = col(pos), len = len })\
	end\
\
	local function push(kind: Token.Kind, text: string, value: any, pos: number)\
		table.insert(tokens, {\
			kind = kind,\
			text = text,\
			value = value,\
			pos = pos,\
			line = line,\
			col = col(pos),\
			spaceBefore = spaceBefore,\
		})\
		spaceBefore = false\
	end\
\
	-- does the char at p keep a bareword going. lets us lex things like 1,200,1\
	-- (vectors), a,b,c (player lists) and 1.5,2,3 as one token instead of choking\
	-- on the comma\
	local function continues(p: number, allowDot: boolean): boolean\
		local c = string.byte(source, p)\
		if isAlphaNum(c) then\
			return true\
		end\
		if c == 45 and isAlpha(string.byte(source, p + 1)) then\
			return true -- internal -letter, eg Ignore-Errors\
		end\
		if c == 44 and isAlphaNum(string.byte(source, p + 1)) then\
			return true -- comma separated list\
		end\
		if allowDot and c == 46 and isDigit(string.byte(source, p + 1)) then\
			return true -- decimal inside a coord\
		end\
		return false\
	end\
\
	while i <= n do\
		local b = string.byte(source, i)\
\
		if b == 32 or b == 9 then\
			-- space / tab\
			spaceBefore = true\
			i += 1\
		elseif b == 10 or b == 13 then\
			-- newline: \\n, \\r, or \\r\\n as one\
			local startPos = i\
			push(Kind.Newline, \"\\n\", nil, startPos)\
			i += 1\
			if b == 13 and string.byte(source, i) == 10 then\
				i += 1\
			end\
			line += 1\
			lineStart = i\
		elseif isDigit(b) then\
			-- NUMBER: digits [ . digits ] (unsigned; sign is the parser's job).\
			-- But a digit run directly followed by a letter is a bareword: 1d, 30s, 5m.\
			local startPos = i\
			while isDigit(string.byte(source, i)) do\
				i += 1\
			end\
			-- optional decimal part\
			if string.byte(source, i) == 46 and isDigit(string.byte(source, i + 1)) then\
				i += 1\
				while isDigit(string.byte(source, i)) do\
					i += 1\
				end\
			end\
			-- if a letter or comma list follows its a bareword (1d, 30s, 1,200,1, 1.5,2,3)\
			if continues(i, true) then\
				while continues(i, true) do\
					i += 1\
				end\
				local text = string.sub(source, startPos, i - 1)\
				push(Kind.Ident, text, text, startPos)\
			else\
				local text = string.sub(source, startPos, i - 1)\
				push(Kind.Number, text, tonumber(text), startPos)\
			end\
		elseif isAlpha(b) then\
			-- IDENT / BOOL. Internal '-' is kept only when followed by a letter/_, so\
			-- `Ignore-Errors` is one ident but `x-2` splits into x, -, 2.\
			local startPos = i\
			i += 1\
			while continues(i, false) do\
				i += 1\
			end\
			local text = string.sub(source, startPos, i - 1)\
			if text == \"true\" then\
				push(Kind.Boolean, text, true, startPos)\
			elseif text == \"false\" then\
				push(Kind.Boolean, text, false, startPos)\
			else\
				push(Kind.Ident, text, text, startPos)\
			end\
		elseif b == 34 then\
			-- STRING with the full Luau escape set.\
			local startPos = i\
			i += 1\
			local buf: { string } = {}\
			local terminated = false\
			while i <= n do\
				local c = string.byte(source, i)\
				if c == 34 then\
					i += 1\
					terminated = true\
					break\
				elseif c == 10 or c == 13 then\
					break -- raw newline => unterminated\
				elseif c == 92 then\
					-- escape\
					i += 1\
					local e = string.byte(source, i)\
					if e == nil then\
						break\
					elseif e == 110 then\
						table.insert(buf, \"\\n\")\
						i += 1\
					elseif e == 116 then\
						table.insert(buf, \"\\t\")\
						i += 1\
					elseif e == 114 then\
						table.insert(buf, \"\\r\")\
						i += 1\
					elseif e == 34 then\
						table.insert(buf, '\"')\
						i += 1\
					elseif e == 92 then\
						table.insert(buf, \"\\\\\")\
						i += 1\
					elseif e == 97 then\
						table.insert(buf, \"\\a\")\
						i += 1\
					elseif e == 98 then\
						table.insert(buf, \"\\b\")\
						i += 1\
					elseif e == 102 then\
						table.insert(buf, \"\\f\")\
						i += 1\
					elseif e == 118 then\
						table.insert(buf, \"\\v\")\
						i += 1\
					elseif e == 120 then\
						-- \\xHH\
						local hex = string.sub(source, i + 1, i + 2)\
						local code = #hex == 2 and tonumber(hex, 16) or nil\
